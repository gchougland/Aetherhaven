$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 420);

    #Title {
      $C.@Title {
        @Text = %server.aetherhaven.ui.chartertown.title;
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 16);

      Label #TownInfo {
        Anchor: (Bottom: 16);
        Style: (...$C.@DefaultLabelStyle, Wrap: true);
      }

      $C.@TextButton #DissolveButton {
        Text: %server.aetherhaven.ui.chartertown.dissolve;
        Disabled: true;
      }

      Label #DissolveHint {
        Anchor: (Top: 8);
        Style: (...$C.@DefaultLabelStyle, TextColor: #888888);
        Text: %server.aetherhaven.ui.chartertown.dissolveHint;
      }
    }
  }
}

$C.@BackButton {}
