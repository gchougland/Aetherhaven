$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 480);

    #Title {
      $C.@Title {
        @Text = %server.aetherhaven.ui.chartertown.title;
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Vertical: 20, Horizontal: 28);

      Group #TownNameEditor {
        LayoutMode: Top;
        Anchor: (Bottom: 16);

        Label #TownNameLabel {
          Text: %server.aetherhaven.ui.chartertown.townNameLabel;
          Anchor: (Bottom: 8);
          Style: (RenderBold: true, RenderUppercase: true, TextColor: #94a7bb, FontSize: 13);
        }

        $C.@TextField #NameInput {
          Anchor: (Top: 8, Height: 44);
          PlaceholderText: %server.aetherhaven.ui.chartertown.namePlaceholder;
        }

        $C.@TextButton #SaveTownNameButton {
          Anchor: (Top: 12);
          Text: %server.aetherhaven.ui.chartertown.saveTownName;
        }
      }

      Label #OwnerOnlyHint {
        Visible: false;
        Anchor: (Bottom: 12);
        Style: (...$C.@DefaultLabelStyle, Wrap: true, TextColor: #8899aa);
        Text: %server.aetherhaven.ui.chartertown.ownerOnlyHint;
      }

      Group #TownInfoSeparator {
        Anchor: (Height: 2, Vertical: 8);
        Background: #292b2a;
      }

      Label #TownInfo {
        Anchor: (Bottom: 12, Width: 424);
        Style: (...$C.@DefaultLabelStyle, Wrap: true, TextColor: #c8d0dc);
      }

      $C.@TextButton #DissolveButton {
        Text: %server.aetherhaven.ui.chartertown.dissolve;
        Visible: false;
        Anchor: (Top: 4);
      }

      Label #DissolveHint {
        Visible: false;
        Anchor: (Top: 8, Width: 424);
        Style: (...$C.@DefaultLabelStyle, Wrap: true, TextColor: #6a7a8a);
        Text: %server.aetherhaven.ui.chartertown.dissolveHint;
      }

      Group #DissolveConfirmGroup {
        LayoutMode: Top;
        Visible: false;
        Anchor: (Top: 8);

        Label #DissolveConfirmText {
          Anchor: (Bottom: 10);
          Style: (...$C.@DefaultLabelStyle, Wrap: true, TextColor: #c49a6c);
          Text: %server.aetherhaven.ui.chartertown.dissolveConfirmText;
        }

        Group {
          LayoutMode: Left;
          Anchor: (Top: 4);

          $C.@TextButton #DissolveConfirmButton {
            Text: %server.aetherhaven.ui.chartertown.dissolveConfirm;
            FlexWeight: 1;
            Anchor: (Right: 6);
          }

          $C.@TextButton #DissolveCancelButton {
            Text: %server.aetherhaven.ui.chartertown.dissolveCancel;
            FlexWeight: 1;
            Anchor: (Left: 6);
          }
        }
      }

      $C.@TextButton #MoveCharterButton {
        Text: %server.aetherhaven.ui.chartertown.moveCharter;
        Visible: false;
        Anchor: (Top: 8);
      }

      Label #MoveCharterHint {
        Visible: false;
        Anchor: (Top: 8, Width: 424);
        Style: (...$C.@DefaultLabelStyle, Wrap: true, TextColor: #6a7a8a);
        Text: %server.aetherhaven.ui.chartertown.moveCharterHint;
      }

      Group #MoveCharterConfirmGroup {
        LayoutMode: Top;
        Visible: false;
        Anchor: (Top: 8);

        Label #MoveCharterConfirmText {
          Anchor: (Bottom: 10);
          Style: (...$C.@DefaultLabelStyle, Wrap: true, TextColor: #c49a6c);
          Text: %server.aetherhaven.ui.chartertown.moveCharterConfirmText;
        }

        Group {
          LayoutMode: Left;
          Anchor: (Top: 4);

          $C.@TextButton #MoveCharterConfirmButton {
            Text: %server.aetherhaven.ui.chartertown.moveCharterConfirm;
            FlexWeight: 1;
            Anchor: (Right: 6);
          }

          $C.@TextButton #MoveCharterCancelButton {
            Text: %server.aetherhaven.ui.chartertown.moveCharterCancel;
            FlexWeight: 1;
            Anchor: (Left: 6);
          }
        }
      }
    }
  }
}

$C.@BackButton {}
