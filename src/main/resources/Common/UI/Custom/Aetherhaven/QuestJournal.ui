$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 560);

    #Title {
      $C.@Title {
        @Text = %server.aetherhaven.ui.questjournal.title;
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 16);

      Label #Hint {
        Anchor: (Bottom: 8);
        Style: (...$C.@DefaultLabelStyle, Wrap: true);
        Text: %server.aetherhaven.ui.questjournal.hint;
      }

      Group #QuestList {
        LayoutMode: Top;
        Anchor: (Bottom: 10);

        Group #QuestRows {
          LayoutMode: Top;
        }
      }

      Label #DetailTitle {
        Anchor: (Bottom: 6);
        Style: (...$C.@DefaultLabelStyle, RenderBold: true, TextColor: #f0e6d2);
        Text: %server.aetherhaven.ui.questjournal.detailPlaceholder;
      }

      Label #DetailBody {
        Style: (...$C.@DefaultLabelStyle, Wrap: true, TextColor: #d8ccb8);
        Text: %server.aetherhaven.ui.questjournal.detailPlaceholderBody;
      }
    }
  }
}

$C.@BackButton {}
