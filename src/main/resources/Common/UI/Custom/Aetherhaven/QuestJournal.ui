$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 560);

    #Title {
      Label #JournalPageTitle {
        Style: (...$C.@TitleStyle, HorizontalAlignment: Center);
        Padding: (Horizontal: 19);
        Text: "";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 16);

      Label #Hint {
        Anchor: (Bottom: 8);
        Style: (...$C.@DefaultLabelStyle, Wrap: true);
        Text: "";
      }

      Group #QuestList {
        LayoutMode: Top;
        Anchor: (Bottom: 10);

        Group #QuestRows {
          LayoutMode: Top;
        }
      }

      Label #DetailTitle {
        Anchor: (Bottom: 6);
        Style: (...$C.@DefaultLabelStyle, RenderBold: true, TextColor: #f0e6d2);
        Text: "";
      }

      Label #DetailBody {
        Style: (...$C.@DefaultLabelStyle, Wrap: true, TextColor: #d8ccb8);
        Text: "";
      }
    }
  }
}

$C.@BackButton {}
