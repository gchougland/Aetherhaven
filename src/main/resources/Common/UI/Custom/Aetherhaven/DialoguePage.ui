$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Bottom;

  Group #DialoguePanel {
    Anchor: (Left: 200, Right: 200, Bottom: 40, Height: 400);
    LayoutMode: Top;
    Padding: (Full: 16);
    Background: (TexturePath: "../Common/ContainerFullPatch.png", Border: 20);

    Group #DialogueFill {
      FlexWeight: 1;
      LayoutMode: Top;

      Group #DialogueColumn {
        Anchor: (Full: 0);
        LayoutMode: Top;

        Group #ReputationRow {
          LayoutMode: Left;
          Anchor: (Bottom: 8);
          Padding: (Horizontal: 4, Vertical: 2);
          HitTestVisible: true;
          Label #ReputationLabel {
            Anchor: (Right: 8, Width: 120);
            Style: (...$C.@DefaultLabelStyle, TextColor: #c4b8a8, RenderBold: true);
            Text: "";
          }
          Group #HeartSlots {
            LayoutMode: Left;
            FlexWeight: 1;
          }
        }

        Group #SpeakerFrame {
          LayoutMode: Left;
          Padding: (Horizontal: 10, Vertical: 8);
          Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);

          AssetImage #Portrait {
            Anchor: (Width: 72, Height: 72, Right: 10);
            FallbackTexturePath: "UI/Custom/Pages/Memories/MissingIcon.png";
          }

          Label #Speaker {
            FlexWeight: 1;
            Anchor: (Bottom: 0);
            Style: (...$C.@DefaultLabelStyle, RenderBold: true, TextColor: #d4c4a8);
          }
        }

        Group #TextBlock {
          LayoutMode: Top;
          Anchor: (Bottom: 8, Height: 108);
          Padding: (Horizontal: 10, Vertical: 8);
          Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);

          Label #BodyText {
            Anchor: (Full: 0);
            Style: (...$C.@DefaultLabelStyle, Wrap: true, TextColor: #e8dcc8);
          }
        }

        Group #ChoicesFrame {
          FlexWeight: 1;
          LayoutMode: Top;
          Anchor: (Top: 2);
          Padding: (Horizontal: 8, Vertical: 8);
          Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);

          Group #ChoicesScroll {
            FlexWeight: 1;
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;

            Group #ChoicesRoot {
              LayoutMode: Top;
            }
          }
        }
      }
    }
  }
}

$C.@BackButton {}
