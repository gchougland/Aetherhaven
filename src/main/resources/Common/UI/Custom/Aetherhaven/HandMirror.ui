$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 920);

    #Title {
      Label #HandMirrorTitleText {
        Style: (...$C.@TitleStyle, HorizontalAlignment: Center);
        Padding: (Horizontal: 19);
        Text: "";
      }
    }

    #Content {
      LayoutMode: Left;
      Padding: (Full: 16);

      Group #LeftColumn {
        LayoutMode: Top;
        FlexWeight: 1;

      Label #EquipSection {
        Anchor: (Bottom: 6);
        Style: (...$C.@DefaultLabelStyle, TextColor: #c8b8a0, Wrap: true);
        Text: "";
      }

      Group #EquippedRow {
        LayoutMode: Left;
        Anchor: (Bottom: 14);

        Group #Ring1Column {
          LayoutMode: Top;
          Label #Ring1Label {
            Style: (...$C.@DefaultLabelStyle, TextColor: #a89878, Wrap: true);
            Text: "";
            Anchor: (Bottom: 4);
          }
          Group #Ring1SlotBox {
            Anchor: (Width: 56, Height: 56);
            LayoutMode: Full;
            Background: #1a2530;
            Padding: 2;
            Group #Ring1Slot {
              LayoutMode: Full;
              ItemGrid #Ring1Icon {
                Anchor: (Full: 0);
                SlotsPerRow: 1;
                Style: (
                  SlotSize: 52,
                  SlotIconSize: 52,
                  SlotSpacing: 0,
                  SlotBackground: "../Common/BlockSelectorSlotBackground.png"
                );
              }
            }
          }
          Button #UnequipRing1 {
            Anchor: (Top: 4, Width: 28, Height: 24);
            Visible: false;
            Style: (
              Default: (Background: (TexturePath: "../eject.png")),
              Hovered: (Background: (TexturePath: "../eject.png", Color: #ffffff(0.18))),
              Pressed: (Background: (TexturePath: "../eject.png", Color: #ffffff(0.38))),
            );
          }
        }

        Group #Ring2Column {
          LayoutMode: Top;
          Label #Ring2Label {
            Style: (...$C.@DefaultLabelStyle, TextColor: #a89878, Wrap: true);
            Text: "";
            Anchor: (Bottom: 4);
          }
          Group #Ring2SlotBox {
            Anchor: (Width: 56, Height: 56);
            LayoutMode: Full;
            Background: #1a2530;
            Padding: 2;
            Group #Ring2Slot {
              LayoutMode: Full;
              ItemGrid #Ring2Icon {
                Anchor: (Full: 0);
                SlotsPerRow: 1;
                Style: (
                  SlotSize: 52,
                  SlotIconSize: 52,
                  SlotSpacing: 0,
                  SlotBackground: "../Common/BlockSelectorSlotBackground.png"
                );
              }
            }
          }
          Button #UnequipRing2 {
            Anchor: (Top: 4, Width: 28, Height: 24);
            Visible: false;
            Style: (
              Default: (Background: (TexturePath: "../eject.png")),
              Hovered: (Background: (TexturePath: "../eject.png", Color: #ffffff(0.18))),
              Pressed: (Background: (TexturePath: "../eject.png", Color: #ffffff(0.38))),
            );
          }
        }

        Group #NeckColumn {
          LayoutMode: Top;
          Label #NeckLabel {
            Style: (...$C.@DefaultLabelStyle, TextColor: #a89878, Wrap: true);
            Text: "";
            Anchor: (Bottom: 4);
          }
          Group #NeckSlotBox {
            Anchor: (Width: 56, Height: 56);
            LayoutMode: Full;
            Background: #1a2530;
            Padding: 2;
            Group #NeckSlot {
              LayoutMode: Full;
              ItemGrid #NeckIcon {
                Anchor: (Full: 0);
                SlotsPerRow: 1;
                Style: (
                  SlotSize: 52,
                  SlotIconSize: 52,
                  SlotSpacing: 0,
                  SlotBackground: "../Common/BlockSelectorSlotBackground.png"
                );
              }
            }
          }
          Button #UnequipNeck {
            Anchor: (Top: 4, Width: 28, Height: 24);
            Visible: false;
            Style: (
              Default: (Background: (TexturePath: "../eject.png")),
              Hovered: (Background: (TexturePath: "../eject.png", Color: #ffffff(0.18))),
              Pressed: (Background: (TexturePath: "../eject.png", Color: #ffffff(0.38))),
            );
          }
        }
      }

      Label #ListSection {
        Anchor: (Bottom: 6);
        Style: (...$C.@DefaultLabelStyle, TextColor: #c8b8a0, Wrap: true);
        Text: "";
      }

      Group #JewelryListScroll {
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Anchor: (Height: 280, Bottom: 10);

        Group #Rows {
          LayoutMode: Top;
        }
      }

      Label #Hint {
        Anchor: (Top: 8);
        Style: (...$C.@DefaultLabelStyle, TextColor: #8a7a60, Wrap: true);
        Text: "";
      }
      }

      Group #TraitColumn {
        LayoutMode: Top;
        Anchor: (Width: 300, Left: 12);
        Padding: (Left: 8);
        Label #TraitTitle {
          Style: (...$C.@DefaultLabelStyle, TextColor: #c8b8a0, Wrap: true);
          Text: "";
        }
        Label #TraitBody {
          Anchor: (Top: 6);
          Style: (...$C.@DefaultLabelStyle, TextColor: #d8d0c8, Wrap: true, FontSize: 13);
          Text: "";
        }
      }
    }
  }
}

$C.@BackButton {}
