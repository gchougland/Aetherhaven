$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 720);

    #Title {
      $C.@Title {
        @Text = %server.aetherhaven.ui.productionUnlocks.title;
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 16);

      Label #UnlockIntro {
        Anchor: (Bottom: 10);
        Style: (...$C.@DefaultLabelStyle, Wrap: true, HorizontalAlignment: Center, TextColor: #c8c0b0, FontSize: 12);
        Text: %server.aetherhaven.ui.productionUnlocks.intro;
      }

      Label #ErrMsg {
        Visible: false;
        Anchor: (Bottom: 8);
        Style: (...$C.@DefaultLabelStyle, Wrap: true, TextColor: #e8a0a0);
        Text: "";
      }

      Group #GridScroll {
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Anchor: (Height: 280, Bottom: 8);

        Group #UnlockRows {
          LayoutMode: Top;
        }
      }

      Group #DetailPanel {
        Visible: false;
        LayoutMode: Top;
        Anchor: (Height: 104, Bottom: 8);
        Padding: (Horizontal: 12, Vertical: 10);
        Background: (TexturePath: "../Common/OptionBackgroundPatch.png", Border: 16);

        Label #DetailName {
          Anchor: (Bottom: 6);
          Style: (...$C.@DefaultLabelStyle, TextColor: #f0e8d8, RenderBold: true, FontSize: 14, Wrap: true);
          Text: "";
        }

        Label #DetailBody {
          Anchor: (Height: 56);
          Style: (...$C.@DefaultLabelStyle, TextColor: #c8c0b0, FontSize: 12, Wrap: true);
          Text: "";
        }
      }

      Group #NavRow {
        LayoutMode: Center;
        Anchor: (Top: 6);

        $C.@TextButton #NavToProduction {
          TextTooltipStyle: $C.@DefaultTextTooltipStyle;
          TooltipText: %server.aetherhaven.ui.productionUnlocks.navProductionTooltip;
          Anchor: (Width: 220, Height: 38);
          Text: %server.aetherhaven.ui.productionUnlocks.navProduction;
        }
      }
    }
  }
}

$C.@BackButton {}
