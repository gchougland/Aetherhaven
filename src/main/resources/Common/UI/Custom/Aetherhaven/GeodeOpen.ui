$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 520);

    #Title {
      $C.@Title {
        @Text = %server.aetherhaven.ui.geodeopen.title;
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 16);

      Label #Hint {
        Anchor: (Bottom: 10);
        Style: (...$C.@DefaultLabelStyle, Wrap: true);
        Text: %server.aetherhaven.ui.geodeopen.hint;
      }

      Group #GeodeRows {
        LayoutMode: Top;
        Anchor: (Bottom: 8);
      }
    }
  }
}

$C.@BackButton {}
