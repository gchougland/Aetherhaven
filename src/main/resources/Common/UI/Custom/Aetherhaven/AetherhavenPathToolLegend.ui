$LegendCommon = "../Hud/ToolsLegends/ToolsLegendsCommon.ui";

$LegendCommon.@Legend {
  #Title {
    Text: "%aetherhaven_items.aetherhaven.pathTool.legendPageTitle";
  }
  #Pages {
    $LegendCommon.@Page #Page1 {
      @Title = "%aetherhaven_items.aetherhaven.pathTool.legendPageTitle";

      $LegendCommon.@RowLabel {
        Text: "%aetherhaven_items.aetherhaven.pathTool.legendBlurb";
        Padding: (Vertical: 6);
      }

      $LegendCommon.@Separator {}

      $LegendCommon.@HotkeyRow {
        @InputBindingKey = "SecondaryItemAction";
        @Description = "%aetherhaven_items.aetherhaven.pathTool.legendHotkeyAdd";
      }

      $LegendCommon.@HotkeyRow {
        @InputBindingKey = "PrimaryItemAction";
        @Description = "%aetherhaven_items.aetherhaven.pathTool.legendHotkeyAim";
      }

      $LegendCommon.@RowLabel {
        Text: "%aetherhaven_items.aetherhaven.pathTool.legendHotkeyUse";
        Padding: (Top: 4);
      }

      $LegendCommon.@RowLabel {
        Text: "%aetherhaven_items.aetherhaven.pathTool.legendHotkeyCrouchUse";
        Padding: (Top: 6);
      }

      $LegendCommon.@Separator {}

      $LegendCommon.@RowLabel {
        Text: "%aetherhaven_items.aetherhaven.pathTool.legendVisuals";
        Style: (FontSize: 13, TextColor: #b8c8d8, Wrap: true);
      }
    }
  }
}
