$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 480);

    #Title {
      $C.@Title {
        @Text = %server.aetherhaven.ui.gaiaStatue.title;
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 16);

      Label #Hint {
        Anchor: (Bottom: 12);
        Style: (...$C.@DefaultLabelStyle, Wrap: true);
      }

      Group #Rows {
        LayoutMode: Top;
      }

      Label #Footer {
        Anchor: (Top: 12);
        Style: (...$C.@DefaultLabelStyle, TextColor: #888888, Wrap: true);
        Text: %server.aetherhaven.ui.gaiaStatue.footer;
      }
    }
  }
}

$C.@BackButton {}
