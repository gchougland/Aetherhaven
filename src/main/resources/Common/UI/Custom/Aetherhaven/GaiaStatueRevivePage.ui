$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 480);

    #Title {
      Label #GaiaReviveTitleText {
        Style: (...$C.@TitleStyle, HorizontalAlignment: Center);
        Padding: (Horizontal: 19);
        Text: "";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 16);

      Label #Hint {
        Anchor: (Bottom: 12);
        Style: (...$C.@DefaultLabelStyle, Wrap: true);
      }

      Group #Rows {
        LayoutMode: Top;
      }

      Label #Footer {
        Anchor: (Top: 12);
        Style: (...$C.@DefaultLabelStyle, TextColor: #888888, Wrap: true);
        Text: "";
      }
    }
  }
}

$C.@BackButton {}
