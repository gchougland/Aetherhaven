$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 560);

    #Title {
      Label #JewelryAppraisalTitleText {
        Style: (...$C.@TitleStyle, HorizontalAlignment: Center);
        Padding: (Horizontal: 19);
        Text: "";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 16);

      Label #Hint {
        Anchor: (Bottom: 10);
        Style: (...$C.@DefaultLabelStyle, Wrap: true);
        Text: "";
      }

      Group #ListScroll {
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Anchor: (Height: 260, Bottom: 10);

        Group #Rows {
          LayoutMode: Top;
        }
      }

      Label #DetailPick {
        Anchor: (Bottom: 6);
        Style: (...$C.@DefaultLabelStyle, TextColor: #a89878, Wrap: true);
        Text: "";
      }

      Label #DetailRarity {
        Anchor: (Bottom: 4);
        Visible: false;
        Style: (...$C.@DefaultLabelStyle, TextColor: #e8dcc8, Wrap: true);
        Text: "";
      }

      Label #DetailTraits {
        Anchor: (Bottom: 8);
        Visible: false;
        Style: (...$C.@DefaultLabelStyle, TextColor: #d8c8a8, Wrap: true);
        Text: "";
      }

      $C.@TextButton #Appraise {
        Anchor: (Bottom: 8);
        Text: "";
      }
    }
  }
}

$C.@BackButton {}
