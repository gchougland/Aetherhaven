$C = "../Common.ui";
$Sounds = "../Sounds.ui";

@IconLbl = (
  FontSize: 6,
  TextColor: #ffffff(0.01),
  HorizontalAlignment: Center,
  VerticalAlignment: Center
);

// Darker = hovered, darkest = pressed (tint via PatchStyle Color).
@IconUpStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../arrow_up_256.png", Border: 0, Color: #ffffff), LabelStyle: (...@IconLbl)),
  Hovered: (Background: PatchStyle(TexturePath: "../arrow_up_256.png", Border: 0, Color: #c5d0dc), LabelStyle: (...@IconLbl)),
  Pressed: (Background: PatchStyle(TexturePath: "../arrow_up_256.png", Border: 0, Color: #8fa0b0), LabelStyle: (...@IconLbl)),
  Disabled: (Background: PatchStyle(TexturePath: "../Common/Buttons/Disabled.png", Border: 12), LabelStyle: (...@IconLbl)),
  Sounds: $Sounds.@ButtonsLight
);
@IconDownStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../arrow_down_256.png", Border: 0, Color: #ffffff), LabelStyle: (...@IconLbl)),
  Hovered: (Background: PatchStyle(TexturePath: "../arrow_down_256.png", Border: 0, Color: #c5d0dc), LabelStyle: (...@IconLbl)),
  Pressed: (Background: PatchStyle(TexturePath: "../arrow_down_256.png", Border: 0, Color: #8fa0b0), LabelStyle: (...@IconLbl)),
  Disabled: (Background: PatchStyle(TexturePath: "../Common/Buttons/Disabled.png", Border: 12), LabelStyle: (...@IconLbl)),
  Sounds: $Sounds.@ButtonsLight
);
@IconBackStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../arrow_back_256.png", Border: 0, Color: #ffffff), LabelStyle: (...@IconLbl)),
  Hovered: (Background: PatchStyle(TexturePath: "../arrow_back_256.png", Border: 0, Color: #c5d0dc), LabelStyle: (...@IconLbl)),
  Pressed: (Background: PatchStyle(TexturePath: "../arrow_back_256.png", Border: 0, Color: #8fa0b0), LabelStyle: (...@IconLbl)),
  Disabled: (Background: PatchStyle(TexturePath: "../Common/Buttons/Disabled.png", Border: 12), LabelStyle: (...@IconLbl)),
  Sounds: $Sounds.@ButtonsLight
);
@IconFwdStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../arrow_forward_256.png", Border: 0, Color: #ffffff), LabelStyle: (...@IconLbl)),
  Hovered: (Background: PatchStyle(TexturePath: "../arrow_forward_256.png", Border: 0, Color: #c5d0dc), LabelStyle: (...@IconLbl)),
  Pressed: (Background: PatchStyle(TexturePath: "../arrow_forward_256.png", Border: 0, Color: #8fa0b0), LabelStyle: (...@IconLbl)),
  Disabled: (Background: PatchStyle(TexturePath: "../Common/Buttons/Disabled.png", Border: 12), LabelStyle: (...@IconLbl)),
  Sounds: $Sounds.@ButtonsLight
);
@IconMinusStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../minus_256.png", Border: 0, Color: #ffffff), LabelStyle: (...@IconLbl)),
  Hovered: (Background: PatchStyle(TexturePath: "../minus_256.png", Border: 0, Color: #c5d0dc), LabelStyle: (...@IconLbl)),
  Pressed: (Background: PatchStyle(TexturePath: "../minus_256.png", Border: 0, Color: #8fa0b0), LabelStyle: (...@IconLbl)),
  Disabled: (Background: PatchStyle(TexturePath: "../Common/Buttons/Disabled.png", Border: 12), LabelStyle: (...@IconLbl)),
  Sounds: $Sounds.@ButtonsLight
);
@IconPlusStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../add_256.png", Border: 0, Color: #ffffff), LabelStyle: (...@IconLbl)),
  Hovered: (Background: PatchStyle(TexturePath: "../add_256.png", Border: 0, Color: #c5d0dc), LabelStyle: (...@IconLbl)),
  Pressed: (Background: PatchStyle(TexturePath: "../add_256.png", Border: 0, Color: #8fa0b0), LabelStyle: (...@IconLbl)),
  Disabled: (Background: PatchStyle(TexturePath: "../Common/Buttons/Disabled.png", Border: 12), LabelStyle: (...@IconLbl)),
  Sounds: $Sounds.@ButtonsLight
);
@IconRotStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../rotate_clockwise_256.png", Border: 0, Color: #ffffff), LabelStyle: (...@IconLbl)),
  Hovered: (Background: PatchStyle(TexturePath: "../rotate_clockwise_256.png", Border: 0, Color: #c5d0dc), LabelStyle: (...@IconLbl)),
  Pressed: (Background: PatchStyle(TexturePath: "../rotate_clockwise_256.png", Border: 0, Color: #8fa0b0), LabelStyle: (...@IconLbl)),
  Disabled: (Background: PatchStyle(TexturePath: "../Common/Buttons/Disabled.png", Border: 12), LabelStyle: (...@IconLbl)),
  Sounds: $Sounds.@ButtonsLight
);
@IconZoomOutStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../zoom_out_256.png", Border: 0, Color: #ffffff), LabelStyle: (...@IconLbl)),
  Hovered: (Background: PatchStyle(TexturePath: "../zoom_out_256.png", Border: 0, Color: #c5d0dc), LabelStyle: (...@IconLbl)),
  Pressed: (Background: PatchStyle(TexturePath: "../zoom_out_256.png", Border: 0, Color: #8fa0b0), LabelStyle: (...@IconLbl)),
  Disabled: (Background: PatchStyle(TexturePath: "../zoom_out_256.png", Border: 0, Color: #5c6a78(0.85)), LabelStyle: (...@IconLbl)),
  Sounds: $Sounds.@ButtonsLight
);
@IconZoomInStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../zoom_in_256.png", Border: 0, Color: #ffffff), LabelStyle: (...@IconLbl)),
  Hovered: (Background: PatchStyle(TexturePath: "../zoom_in_256.png", Border: 0, Color: #c5d0dc), LabelStyle: (...@IconLbl)),
  Pressed: (Background: PatchStyle(TexturePath: "../zoom_in_256.png", Border: 0, Color: #8fa0b0), LabelStyle: (...@IconLbl)),
  Disabled: (Background: PatchStyle(TexturePath: "../zoom_in_256.png", Border: 0, Color: #5c6a78(0.85)), LabelStyle: (...@IconLbl)),
  Sounds: $Sounds.@ButtonsLight
);

@SummaryLabelStyle = (
  FontSize: 18,
  TextColor: #e8f0f4,
  RenderBold: true,
  Wrap: true,
  HorizontalAlignment: Start
);

@MutedBodyStyle = (
  FontSize: 14,
  TextColor: $C.@ColorGrayCaption,
  Wrap: true,
  HorizontalAlignment: Start
);

$C.@PageOverlay {
  LayoutMode: Top;
  Anchor: (Left: 16, Top: 28, Bottom: 80, Width: 480);

  $C.@DecoratedContainer {
    FlexWeight: 1;
    Anchor: (Width: 480, Top: 0, Bottom: 0);

    #Title {
      $C.@Title {
        @Text = %server.aetherhaven.ui.plotplacement.title;
      }
    }

    #Content {
      LayoutMode: Top;
      Anchor: (Top: $C.@TitleHeight, Bottom: 0);
      Padding: (Top: 14, Left: 14, Right: 14, Bottom: 44);

      Label #Summary {
        Anchor: (Bottom: 12, Width: 448);
        Style: (...@SummaryLabelStyle);
      }

      Label #Details {
        Anchor: (Bottom: 10, Width: 448);
        Style: (...@MutedBodyStyle);
      }

      Label #Tips {
        Anchor: (Bottom: 14, Width: 448);
        Style: (...@MutedBodyStyle);
      }

      Label #PlotTypeLabel {
        Anchor: (Bottom: 6);
        Style: (...$C.@SubtitleStyle);
        Text: %server.aetherhaven.ui.plotplacement.plotType;
        Visible: false;
      }

      $C.@DropdownBox #PlotTypeDropdown {
        Anchor: (Bottom: 12, Width: 448, Height: $C.@DropdownBoxHeight);
        Visible: false;
      }

      $C.@CheckBoxWithLabel #BirdsEyeToggle {
        @Text = %server.aetherhaven.ui.plotplacement.birdsEye;
        TextTooltipStyle: $C.@DefaultTextTooltipStyle;
        TooltipText: %server.aetherhaven.ui.plotplacement.birdsEyeTooltip;
        Anchor: (Bottom: 8);
      }

      Group #BirdsEyeZoomRow {
        LayoutMode: Left;
        Anchor: (Bottom: 10);
        Visible: false;

        TextButton #BtnZoomIn {
          Style: @IconZoomInStyle;
          TextTooltipStyle: $C.@DefaultTextTooltipStyle;
          Anchor: (Width: 34, Height: 34, Right: 6);
          Padding: (Full: 0);
          Text: ".";
          TooltipText: %server.aetherhaven.ui.plotplacement.zoomInTooltip;
        }

        $C.@FloatSlider #BirdsEyeDistanceSlider {
          Anchor: (Width: 200, Height: 5, Right: 8);
          Min: 12.0;
          Max: 48.0;
          Value: 20.0;
        }

        TextButton #BtnZoomOut {
          Style: @IconZoomOutStyle;
          TextTooltipStyle: $C.@DefaultTextTooltipStyle;
          Anchor: (Width: 34, Height: 34, Right: 8);
          Padding: (Full: 0);
          Text: ".";
          TooltipText: %server.aetherhaven.ui.plotplacement.zoomOutTooltip;
        }

        Label #BirdsEyeDistanceValue {
          Anchor: (Width: 34);
          Style: (...$C.@DefaultLabelStyle, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "20";
        }
      }

      // Bird's-eye: pan (camera) | plot move side by side. First-person: only plot column (full width).
      Group #CameraPlotRow {
        LayoutMode: Left;
        Anchor: (Bottom: 12);

        Group #BirdsEyePanColumn {
          LayoutMode: Top;
          FlexWeight: 1;
          Visible: false;

          Group {
            LayoutMode: Center;
            Anchor: (Bottom: 22);
            TextButton #BtnPanZm {
              Style: @IconUpStyle;
              TextTooltipStyle: $C.@DefaultTextTooltipStyle;
              Anchor: (Width: 44, Height: 40);
              Padding: (Full: 0);
              Text: ".";
              TooltipText: %server.aetherhaven.ui.plotplacement.panZmTooltip;
            }
          }

          Group {
            LayoutMode: Center;
            Anchor: (Bottom: 22);
            Group {
              LayoutMode: Left;
              TextButton #BtnPanXm {
                Style: @IconBackStyle;
                TextTooltipStyle: $C.@DefaultTextTooltipStyle;
                Anchor: (Width: 44, Height: 40);
                Padding: (Full: 0);
                Text: ".";
                TooltipText: %server.aetherhaven.ui.plotplacement.panXmTooltip;
              }
              AssetImage #CameraPadIcon {
                Anchor: (Width: 36, Height: 36, Left: 8);
                AssetPath: "UI/Custom/camera_icon_256.png";
              }
              TextButton #BtnPanXp {
                Style: @IconFwdStyle;
                TextTooltipStyle: $C.@DefaultTextTooltipStyle;
                Anchor: (Width: 44, Height: 40, Left: 8);
                Padding: (Full: 0);
                Text: ".";
                TooltipText: %server.aetherhaven.ui.plotplacement.panXpTooltip;
              }
            }
          }

          Group {
            LayoutMode: Center;
            TextButton #BtnPanZp {
              Style: @IconDownStyle;
              TextTooltipStyle: $C.@DefaultTextTooltipStyle;
              Anchor: (Width: 44, Height: 40);
              Padding: (Full: 0);
              Text: ".";
              TooltipText: %server.aetherhaven.ui.plotplacement.panZpTooltip;
            }
          }
        }

        Group #PlotMovePad {
          LayoutMode: Top;
          FlexWeight: 1;

          Group {
            LayoutMode: Center;
            Anchor: (Bottom: 22);
            TextButton #BtnZm {
              Style: @IconUpStyle;
              TextTooltipStyle: $C.@DefaultTextTooltipStyle;
              Anchor: (Width: 44, Height: 40);
              Padding: (Full: 0);
              Text: ".";
              TooltipText: %server.aetherhaven.ui.plotplacement.moveZmTooltip;
            }
          }

          Group {
            LayoutMode: Center;
            Anchor: (Bottom: 22);
            Group {
              LayoutMode: Left;
              TextButton #BtnXm {
                Style: @IconBackStyle;
                TextTooltipStyle: $C.@DefaultTextTooltipStyle;
                Anchor: (Width: 44, Height: 40);
                Padding: (Full: 0);
                Text: ".";
                TooltipText: %server.aetherhaven.ui.plotplacement.moveXmTooltip;
              }
              AssetImage #PlotPadIcon {
                Anchor: (Width: 36, Height: 36, Left: 8);
                AssetPath: "UI/Custom/house_icon_256.png";
              }
              TextButton #BtnXp {
                Style: @IconFwdStyle;
                TextTooltipStyle: $C.@DefaultTextTooltipStyle;
                Anchor: (Width: 44, Height: 40, Left: 8);
                Padding: (Full: 0);
                Text: ".";
                TooltipText: %server.aetherhaven.ui.plotplacement.moveXpTooltip;
              }
            }
          }

          Group {
            LayoutMode: Center;
            TextButton #BtnZp {
              Style: @IconDownStyle;
              TextTooltipStyle: $C.@DefaultTextTooltipStyle;
              Anchor: (Width: 44, Height: 40);
              Padding: (Full: 0);
              Text: ".";
              TooltipText: %server.aetherhaven.ui.plotplacement.moveZpTooltip;
            }
          }
        }
      }

      Label #HeightLabel {
        Anchor: (Top: 4, Bottom: 6);
        Style: (...$C.@SubtitleStyle);
        Text: %server.aetherhaven.ui.plotplacement.heightSection;
      }

      Group #RowYRot {
        LayoutMode: Center;
        Anchor: (Bottom: 8, Left: 0, Right: 0);
        Group {
          LayoutMode: Left;
          TextButton #BtnYm {
            Style: @IconMinusStyle;
            TextTooltipStyle: $C.@DefaultTextTooltipStyle;
            Anchor: (Width: 40, Height: 40);
            Padding: (Full: 0);
            Text: ".";
            TooltipText: %server.aetherhaven.ui.plotplacement.moveYmTooltip;
          }
          TextButton #BtnYp {
            Style: @IconPlusStyle;
            TextTooltipStyle: $C.@DefaultTextTooltipStyle;
            Anchor: (Width: 40, Height: 40, Left: 8);
            Padding: (Full: 0);
            Text: ".";
            TooltipText: %server.aetherhaven.ui.plotplacement.moveYpTooltip;
          }
          TextButton #BtnRotate {
            Style: @IconRotStyle;
            TextTooltipStyle: $C.@DefaultTextTooltipStyle;
            Anchor: (Width: 44, Height: 40, Left: 10);
            Padding: (Full: 0);
            Text: ".";
            TooltipText: %server.aetherhaven.ui.plotplacement.rotateTooltip;
          }
        }
      }

      Group {
        FlexWeight: 1;
      }

      Group #MoveConfirmGroup {
        LayoutMode: Top;
        Visible: false;
        Anchor: (Bottom: 12);

        Label #MoveConfirmText {
          Anchor: (Bottom: 10, Width: 448);
          Style: (...$C.@DefaultLabelStyle, Wrap: true, TextColor: #c49a6c, HorizontalAlignment: Start);
          Text: %server.aetherhaven.ui.plotplacement.moveWarningText;
        }

        Group {
          LayoutMode: Left;
          Anchor: (Top: 4);

          $C.@TextButton #MoveConfirmButton {
            Text: %server.aetherhaven.ui.plotplacement.moveConfirm;
            FlexWeight: 1;
            Anchor: (Right: 6);
          }

          $C.@TextButton #MoveConfirmBackButton {
            Text: %server.aetherhaven.ui.plotplacement.moveBack;
            FlexWeight: 1;
            Anchor: (Left: 6);
          }
        }
      }

      Group #RowActions {
        LayoutMode: Center;
        Anchor: (Top: 8, Left: 0, Right: 0);
        Group {
          LayoutMode: Left;
          $C.@TextButton #PlaceButton {
            Text: %server.aetherhaven.ui.plotplacement.place;
            Anchor: (Right: 10, Width: 200, Height: 48);
            Padding: (Horizontal: 10, Vertical: 10);
          }
          $C.@CancelTextButton #CancelButton {
            Text: %server.aetherhaven.ui.plotplacement.cancel;
            Anchor: (Width: 200, Height: 48);
            Padding: (Horizontal: 10, Vertical: 10);
          }
        }
      }
    }
  }
}

$C.@BackButton {}
