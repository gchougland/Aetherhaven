$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 420);

    #Title {
      $C.@Title {
        @Text = %server.aetherhaven.ui.treasury.title;
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 16);

      Label #Balance {
        Anchor: (Bottom: 12);
        Style: (...$C.@DefaultLabelStyle, Wrap: true);
      }

      $C.@TextButton #DepositButton {
        Text: %server.aetherhaven.ui.treasury.deposit;
      }

      $C.@TextButton #WithdrawButton {
        Anchor: (Top: 8);
        Text: %server.aetherhaven.ui.treasury.withdraw;
      }

      Label #Hint {
        Anchor: (Top: 12);
        Style: (...$C.@DefaultLabelStyle, TextColor: #888888, Wrap: true);
        Text: %server.aetherhaven.ui.treasury.hint;
      }
    }
  }
}

$C.@BackButton {}
