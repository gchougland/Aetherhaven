$C = "../Common.ui";

@NodeBtnStyle = (
  Default: (Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 10, Color: #252b38(0.98))),
  Hovered: (Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 10, Color: #323a4c(0.98))),
  Pressed: (Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 10, Color: #1c2230(0.98))),
  Disabled: (Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 10, Color: #141820(0.96)))
);

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 720);

    #Title {
      $C.@Title {
        @Text = %server.aetherhaven.ui.feast.title;
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 16);

      Group #HeaderRow {
        LayoutMode: Left;
        Anchor: (Bottom: 12);

        Group #TrayFrame {
          LayoutMode: Full;
          Anchor: (Width: 44, Height: 44, Right: 10);
          Padding: (Full: 2);
          Background: #5a5468;

          Group #TrayInner {
            LayoutMode: Full;
            Anchor: (Full: 0);
            Padding: (Full: 3);
            Background: #1c2230;

            AssetImage #TrayIcon {
              Anchor: (Full: 0);
              AssetPath: "../food-tray.png";
            }
          }
        }

        Label #HeaderSpacer {
          FlexWeight: 1;
        }
      }

      Group #MainRow {
        LayoutMode: Left;
        Anchor: (Top: 8);

        Group #LeftPanel {
          LayoutMode: Top;
          Anchor: (Width: 220, Right: 14);

          Label #GridLabel {
            Anchor: (Bottom: 8);
            Style: (...$C.@DefaultLabelStyle, TextColor: #c8c0b0);
            Text: %server.aetherhaven.ui.feast.selectHint;
          }

          Group #FeastGrid {
            LayoutMode: Left;

            Button #FeastPick0 {
              LayoutMode: Top;
              Style: @NodeBtnStyle;
              TextTooltipStyle: $C.@DefaultTextTooltipStyle;
              Anchor: (Width: 72, Right: 8);
              Padding: (Horizontal: 6, Vertical: 6);

              Group #Feast0Frame {
                LayoutMode: Full;
                Anchor: (Width: 52, Height: 52);
                Padding: (Full: 2);
                Background: #5a5468;

                Group #Feast0Stack {
                  LayoutMode: Full;
                  Anchor: (Full: 0);
                  Padding: (Full: 3);
                  Background: #1c2230;

                  AssetImage #Feast0Icon {
                    Anchor: (Full: 0);
                    AssetPath: "../fast-food.png";
                  }

                  Group #Feast0Dim {
                    LayoutMode: Full;
                    Anchor: (Full: 0);
                    Visible: false;
                    Background: #000000(0.55);
                  }
                }
              }
            }

            Button #FeastPick1 {
              LayoutMode: Top;
              Style: @NodeBtnStyle;
              TextTooltipStyle: $C.@DefaultTextTooltipStyle;
              Anchor: (Width: 72, Right: 8);
              Padding: (Horizontal: 6, Vertical: 6);

              Group #Feast1Frame {
                LayoutMode: Full;
                Anchor: (Width: 52, Height: 52);
                Padding: (Full: 2);
                Background: #5a5468;

                Group #Feast1Stack {
                  LayoutMode: Full;
                  Anchor: (Full: 0);
                  Padding: (Full: 3);
                  Background: #1c2230;

                  AssetImage #Feast1Icon {
                    Anchor: (Full: 0);
                    AssetPath: "../taco.png";
                  }

                  Group #Feast1Dim {
                    LayoutMode: Full;
                    Anchor: (Full: 0);
                    Visible: false;
                    Background: #000000(0.55);
                  }
                }
              }
            }

            Button #FeastPick2 {
              LayoutMode: Top;
              Style: @NodeBtnStyle;
              TextTooltipStyle: $C.@DefaultTextTooltipStyle;
              Anchor: (Width: 72);
              Padding: (Horizontal: 6, Vertical: 6);

              Group #Feast2Frame {
                LayoutMode: Full;
                Anchor: (Width: 52, Height: 52);
                Padding: (Full: 2);
                Background: #5a5468;

                Group #Feast2Stack {
                  LayoutMode: Full;
                  Anchor: (Full: 0);
                  Padding: (Full: 3);
                  Background: #1c2230;

                  AssetImage #Feast2Icon {
                    Anchor: (Full: 0);
                    AssetPath: "../salad.png";
                  }

                  Group #Feast2Dim {
                    LayoutMode: Full;
                    Anchor: (Full: 0);
                    Visible: false;
                    Background: #000000(0.55);
                  }
                }
              }
            }
          }
        }

        Group #RightPanel {
          LayoutMode: Top;
          FlexWeight: 1;

          Label #RightTitle {
            Anchor: (Bottom: 8);
            Style: (...$C.@DefaultLabelStyle, RenderBold: true, Wrap: true);
            Text: "";
          }

          Label #RightBody {
            Anchor: (Bottom: 10);
            Style: (...$C.@DefaultLabelStyle, Wrap: true, TextColor: #d8d0c8);
            Text: "";
          }

          Label #RightCosts {
            Anchor: (Bottom: 12);
            Style: (...$C.@DefaultLabelStyle, Wrap: true, TextColor: #b8b0a8);
            Text: "";
          }

          $C.@TextButton #ConfirmFeast {
            Anchor: (Top: 8);
            Text: %server.aetherhaven.ui.feast.confirm;
          }
        }
      }
    }
  }
}

$C.@BackButton {}
