$C = "../Common.ui";

Group #QuestRow {
  LayoutMode: Left;
  Anchor: (Bottom: 6);
  Padding: (Horizontal: 4, Vertical: 3);
  Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);

  Button #Select {
    LayoutMode: Left;
    FlexWeight: 1;
    Padding: (Horizontal: 8, Vertical: 6);
    Style: (
      Default: (Background: #000000(0.0)),
      Hovered: (Background: #ffffff(0.08)),
      Pressed: (Background: #ffffff(0.12))
    );

    Label #QuestTitle {
      Style: (...$C.@DefaultLabelStyle, RenderBold: true, TextColor: #e8dcc8, Wrap: true);
      FlexWeight: 1;
    }
  }
}
