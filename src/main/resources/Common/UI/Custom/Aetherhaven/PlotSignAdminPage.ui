$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 480);

    #Title {
      Label #PlotSignAdminTitleText {
        Style: (...$C.@TitleStyle, HorizontalAlignment: Center);
        Padding: (Horizontal: 19);
        Text: "";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 16);

      Group #Construction {
        LayoutMode: Left;
        Anchor: (Bottom: 16);

        Label #ConstructionFieldLabel {
          Text: "";
          Anchor: (Top: 6, Left: 6, Right: 16);
          Style: $C.@DefaultLabelStyle;
        }

        $C.@DropdownBox #Input {
          @Anchor = (Left: 0, Right: 16);
        }
      }

      $C.@TextButton #GiveButton {
        Text: "";
      }
    }
  }
}

$C.@BackButton {}
