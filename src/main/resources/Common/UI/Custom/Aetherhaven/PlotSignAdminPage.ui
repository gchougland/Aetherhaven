$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 480);

    #Title {
      $C.@Title {
        @Text = %server.aetherhaven.ui.plotadmin.title;
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 16);

      Group #Construction {
        LayoutMode: Left;
        Anchor: (Bottom: 16);

        Label {
          Text: %server.aetherhaven.ui.plotadmin.construction;
          Anchor: (Top: 6, Left: 6, Right: 16);
          Style: $C.@DefaultLabelStyle;
        }

        $C.@DropdownBox #Input {
          @Anchor = (Left: 0, Right: 16);
        }
      }

      $C.@TextButton #GiveButton {
        Text: %server.aetherhaven.ui.plotadmin.give;
      }
    }
  }
}

$C.@BackButton {}
