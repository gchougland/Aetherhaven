$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 480);

    #Title {
      Label #ShellTitleText {
        Style: (...$C.@TitleStyle, HorizontalAlignment: Center);
        Padding: (Horizontal: 19);
        Text: %server.aetherhaven.ui.plotconstruction.title;
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 16);

      Group #ManagementTabStrip {
        LayoutMode: Left;
        Visible: false;
        Anchor: (Bottom: 14, Left: 0, Right: 0);
        Padding: (Horizontal: 4, Vertical: 6);
        Background: #1e2430(0.85);

        $C.@TextButton #TabPlotButton {
          Text: %server.aetherhaven.ui.plotmanagement.tabPlot;
          FlexWeight: 1;
          Anchor: (Right: 4, Height: 36);
        }

        $C.@TextButton #TabPlayersButton {
          Text: %server.aetherhaven.ui.plotmanagement.tabPlayers;
          FlexWeight: 1;
          Anchor: (Left: 4, Height: 36);
        }
      }

      Group #PlotTabContent {
        LayoutMode: Top;

        Label #BuildingTitle {
          Anchor: (Bottom: 8);
          Style: (...$C.@DefaultLabelStyle, RenderBold: true);
        }

        Label #Description {
          Anchor: (Left: 0, Right: 0, Bottom: 12);
          Style: (...$C.@DefaultLabelStyle, Wrap: true);
        }

        Group #VillagerRow {
          LayoutMode: Top;
          Visible: false;
          Anchor: (Bottom: 12);

          Label #VillagerLabel {
            Style: $C.@DefaultLabelStyle;
          }
        }

        Group #TreasuryRow {
          LayoutMode: Top;
          Visible: false;
          Anchor: (Bottom: 12);

          Label #TreasuryLabel {
            Style: $C.@DefaultLabelStyle;
          }
        }

        Label #MaterialsHeader {
          Text: %server.aetherhaven.ui.plotconstruction.materials;
          Anchor: (Bottom: 6);
          Style: (...$C.@DefaultLabelStyle, RenderBold: true);
        }

        Group #Mat0 { LayoutMode: Top; Anchor: (Bottom: 4); Label #Line { Style: $C.@DefaultLabelStyle; } }
        Group #Mat1 { LayoutMode: Top; Anchor: (Bottom: 4); Label #Line { Style: $C.@DefaultLabelStyle; } }
        Group #Mat2 { LayoutMode: Top; Anchor: (Bottom: 4); Label #Line { Style: $C.@DefaultLabelStyle; } }
        Group #Mat3 { LayoutMode: Top; Anchor: (Bottom: 4); Label #Line { Style: $C.@DefaultLabelStyle; } }
        Group #Mat4 { LayoutMode: Top; Anchor: (Bottom: 4); Label #Line { Style: $C.@DefaultLabelStyle; } }
        Group #Mat5 { LayoutMode: Top; Anchor: (Bottom: 4); Label #Line { Style: $C.@DefaultLabelStyle; } }
        Group #Mat6 { LayoutMode: Top; Anchor: (Bottom: 4); Label #Line { Style: $C.@DefaultLabelStyle; } }
        Group #Mat7 { LayoutMode: Top; Anchor: (Bottom: 4); Label #Line { Style: $C.@DefaultLabelStyle; } }
        Group #Mat8 { LayoutMode: Top; Anchor: (Bottom: 4); Label #Line { Style: $C.@DefaultLabelStyle; } }
        Group #Mat9 { LayoutMode: Top; Anchor: (Bottom: 4); Label #Line { Style: $C.@DefaultLabelStyle; } }

        Group {
          Anchor: (Vertical: 12, Height: 1);
          Background: #5e512c(0.0);
        }

        $C.@TextButton #TownNeedsButton {
          Text: %server.aetherhaven.ui.plotconstruction.townNeeds;
          Visible: false;
          Anchor: (Bottom: 8);
        }

        $C.@TextButton #MoveBuildingButton {
          Text: %server.aetherhaven.ui.plotconstruction.moveBuilding;
          Visible: false;
          Anchor: (Bottom: 8);
        }

        Group #HouseResidentRow {
          LayoutMode: Top;
          Visible: false;
          Anchor: (Bottom: 12);

          Label #HouseResidentHint {
            Style: (...$C.@DefaultLabelStyle, Wrap: true);
            Anchor: (Bottom: 8);
          }

          Group #HouseResidentDropdown {
            LayoutMode: Left;
            Anchor: (Bottom: 8);

            Label {
              Text: %server.aetherhaven.ui.plotconstruction.houseResident;
              Anchor: (Top: 6, Left: 6, Right: 16);
              Style: $C.@DefaultLabelStyle;
            }

            $C.@DropdownBox #Input {
              @Anchor = (Left: 0, Right: 16);
            }
          }

          $C.@TextButton #AssignHouseResidentButton {
            Text: %server.aetherhaven.ui.plotconstruction.assignHouseResident;
          }
        }

        $C.@TextButton #PickUpPlotButton {
          Text: %server.aetherhaven.ui.plotconstruction.pickUpPlot;
          Visible: false;
          Anchor: (Bottom: 8);
        }

        $C.@TextButton #BuildButton {
          Text: %server.aetherhaven.ui.plotconstruction.build;
        }
      }

      Group #PlayersTabContent {
        LayoutMode: Top;
        Visible: false;

        Label #PlayersHint {
          Anchor: (Bottom: 8);
          Style: (...$C.@DefaultLabelStyle, Wrap: true);
          Text: %server.aetherhaven.ui.plotmanagement.playersHint;
        }

        Group #MemberRows {
          LayoutMode: Top;
        }

        Label #InviteLabel {
          Text: %server.aetherhaven.ui.plotmanagement.inviteLabel;
          Anchor: (Top: 12, Bottom: 6);
          Style: (...$C.@DefaultLabelStyle, RenderBold: true);
        }

        $C.@TextField #InvitePlayerInput {
          Anchor: (Top: 4, Height: 44, Left: 0, Right: 0);
          PlaceholderText: %server.aetherhaven.ui.plotmanagement.invitePlaceholder;
        }

        $C.@TextButton #InviteSendButton {
          Text: %server.aetherhaven.ui.plotmanagement.inviteSend;
          Anchor: (Top: 14);
        }
      }
    }
  }
}

$C.@BackButton {}
