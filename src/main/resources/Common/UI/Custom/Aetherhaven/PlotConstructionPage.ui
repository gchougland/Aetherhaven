$C = "../Common.ui";
$Sounds = "../Sounds.ui";

@TabIconLbl = (
  FontSize: 6,
  TextColor: #ffffff(0.01),
  HorizontalAlignment: Center,
  VerticalAlignment: Center
);

@MgmtTabIconStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../house_icon_256.png", Border: 0, Color: #ffffff), LabelStyle: (...@TabIconLbl)),
  Hovered: (Background: PatchStyle(TexturePath: "../house_icon_256.png", Border: 0, Color: #c5d0dc), LabelStyle: (...@TabIconLbl)),
  Pressed: (Background: PatchStyle(TexturePath: "../house_icon_256.png", Border: 0, Color: #8fa0b0), LabelStyle: (...@TabIconLbl)),
  Disabled: (Background: PatchStyle(TexturePath: "../house_icon_256.png", Border: 0, Color: #5c6a78(0.85)), LabelStyle: (...@TabIconLbl)),
  Sounds: $Sounds.@ButtonsLight
);
@MgmtTabFoodStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../food_icon_256.png", Border: 0, Color: #ffffff), LabelStyle: (...@TabIconLbl)),
  Hovered: (Background: PatchStyle(TexturePath: "../food_icon_256.png", Border: 0, Color: #c5d0dc), LabelStyle: (...@TabIconLbl)),
  Pressed: (Background: PatchStyle(TexturePath: "../food_icon_256.png", Border: 0, Color: #8fa0b0), LabelStyle: (...@TabIconLbl)),
  Disabled: (Background: PatchStyle(TexturePath: "../food_icon_256.png", Border: 0, Color: #5c6a78(0.85)), LabelStyle: (...@TabIconLbl)),
  Sounds: $Sounds.@ButtonsLight
);
@MgmtTabGroupStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../group_icon_256.png", Border: 0, Color: #ffffff), LabelStyle: (...@TabIconLbl)),
  Hovered: (Background: PatchStyle(TexturePath: "../group_icon_256.png", Border: 0, Color: #c5d0dc), LabelStyle: (...@TabIconLbl)),
  Pressed: (Background: PatchStyle(TexturePath: "../group_icon_256.png", Border: 0, Color: #8fa0b0), LabelStyle: (...@TabIconLbl)),
  Disabled: (Background: PatchStyle(TexturePath: "../group_icon_256.png", Border: 0, Color: #5c6a78(0.85)), LabelStyle: (...@TabIconLbl)),
  Sounds: $Sounds.@ButtonsLight
);
@MgmtTabMoveStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../move_icon_256.png", Border: 0, Color: #ffffff), LabelStyle: (...@TabIconLbl)),
  Hovered: (Background: PatchStyle(TexturePath: "../move_icon_256.png", Border: 0, Color: #c5d0dc), LabelStyle: (...@TabIconLbl)),
  Pressed: (Background: PatchStyle(TexturePath: "../move_icon_256.png", Border: 0, Color: #8fa0b0), LabelStyle: (...@TabIconLbl)),
  Disabled: (Background: PatchStyle(TexturePath: "../move_icon_256.png", Border: 0, Color: #5c6a78(0.85)), LabelStyle: (...@TabIconLbl)),
  Sounds: $Sounds.@ButtonsLight
);

$C.@PageOverlay {
  LayoutMode: Top;

  Group {
    FlexWeight: 1;
    Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);

    Group {
      LayoutMode: Middle;
      Anchor: (Full: 0);

    $C.@DecoratedContainer {
      Anchor: (Width: 480);

      #Title {
        Label #ShellTitleText {
          Style: (...$C.@TitleStyle, HorizontalAlignment: Center);
          Padding: (Horizontal: 19);
          Text: "";
        }
      }

      #Content {
        LayoutMode: Top;
        Padding: (Full: 16);

        Group #ManagementTabStrip {
          LayoutMode: Left;
          Visible: false;
          Anchor: (Bottom: 14, Left: 0, Right: 0);
          Padding: (Horizontal: 6, Vertical: 8);
          Background: #1e2430(0.92);

          TextButton #TabPlotButton {
            Style: @MgmtTabIconStyle;
            TextTooltipStyle: $C.@DefaultTextTooltipStyle;
            FlexWeight: 1;
            Anchor: (Right: 4, Height: 40, Width: 44);
            Padding: (Full: 0);
            Text: ".";
            TooltipText: "";
          }

          TextButton #TabNeedsButton {
            Style: @MgmtTabFoodStyle;
            TextTooltipStyle: $C.@DefaultTextTooltipStyle;
            FlexWeight: 1;
            Anchor: (Right: 4, Height: 40, Width: 44);
            Padding: (Full: 0);
            Text: ".";
            TooltipText: "";
          }

          TextButton #TabPlayersButton {
            Style: @MgmtTabGroupStyle;
            TextTooltipStyle: $C.@DefaultTextTooltipStyle;
            FlexWeight: 1;
            Anchor: (Right: 4, Height: 40, Width: 44);
            Padding: (Full: 0);
            Text: ".";
            TooltipText: "";
          }

          TextButton #TabMoveButton {
            Style: @MgmtTabMoveStyle;
            TextTooltipStyle: $C.@DefaultTextTooltipStyle;
            FlexWeight: 1;
            Anchor: (Height: 40, Width: 44);
            Padding: (Full: 0);
            Text: ".";
            TooltipText: "";
          }
        }

        Group #PlotTabContent {
          LayoutMode: Top;

          Label #BuildingTitle {
            Anchor: (Bottom: 8);
            Style: (...$C.@DefaultLabelStyle, RenderBold: true);
          }

          Label #Description {
            Anchor: (Left: 0, Right: 0, Bottom: 12);
            Style: (...$C.@DefaultLabelStyle, Wrap: true);
          }

          Group #VillagerRow {
            LayoutMode: Top;
            Visible: false;
            Anchor: (Bottom: 12);

            Label #VillagerLabel {
              Style: $C.@DefaultLabelStyle;
            }
          }

          Group #TreasuryRow {
            LayoutMode: Top;
            Visible: false;
            Anchor: (Bottom: 12);

            Label #TreasuryLabel {
              Style: $C.@DefaultLabelStyle;
            }
          }

          Label #MaterialsHeader {
            Text: "";
            Anchor: (Bottom: 6);
            Style: (...$C.@DefaultLabelStyle, RenderBold: true);
          }

          Group #Mat0 { LayoutMode: Top; Anchor: (Bottom: 4); Label #Line { Style: $C.@DefaultLabelStyle; } }
          Group #Mat1 { LayoutMode: Top; Anchor: (Bottom: 4); Label #Line { Style: $C.@DefaultLabelStyle; } }
          Group #Mat2 { LayoutMode: Top; Anchor: (Bottom: 4); Label #Line { Style: $C.@DefaultLabelStyle; } }
          Group #Mat3 { LayoutMode: Top; Anchor: (Bottom: 4); Label #Line { Style: $C.@DefaultLabelStyle; } }
          Group #Mat4 { LayoutMode: Top; Anchor: (Bottom: 4); Label #Line { Style: $C.@DefaultLabelStyle; } }
          Group #Mat5 { LayoutMode: Top; Anchor: (Bottom: 4); Label #Line { Style: $C.@DefaultLabelStyle; } }
          Group #Mat6 { LayoutMode: Top; Anchor: (Bottom: 4); Label #Line { Style: $C.@DefaultLabelStyle; } }
          Group #Mat7 { LayoutMode: Top; Anchor: (Bottom: 4); Label #Line { Style: $C.@DefaultLabelStyle; } }
          Group #Mat8 { LayoutMode: Top; Anchor: (Bottom: 4); Label #Line { Style: $C.@DefaultLabelStyle; } }
          Group #Mat9 { LayoutMode: Top; Anchor: (Bottom: 4); Label #Line { Style: $C.@DefaultLabelStyle; } }

          Group {
            Anchor: (Vertical: 12, Height: 1);
            Background: #5e512c(0.0);
          }

          Group #HouseResidentRow {
            LayoutMode: Top;
            Visible: false;
            Anchor: (Bottom: 12);

            Label #HouseResidentHint {
              Style: (...$C.@DefaultLabelStyle, Wrap: true);
              Anchor: (Bottom: 8);
            }

            Group #HouseResidentDropdown {
              LayoutMode: Left;
              Anchor: (Bottom: 8);

              Label #HouseResidentFieldLabel {
                Text: "";
                Anchor: (Top: 6, Left: 6, Right: 16);
                Style: $C.@DefaultLabelStyle;
              }

              $C.@DropdownBox #Input {
                @Anchor = (Left: 0, Right: 16);
              }
            }

            $C.@TextButton #AssignHouseResidentButton {
              Text: "";
            }
          }

          $C.@TextButton #PickUpPlotButton {
            Text: "";
            Visible: false;
            Anchor: (Bottom: 8);
          }

          $C.@TextButton #BuildButton {
            Text: "";
          }
        }

        Group #PlayersTabContent {
          LayoutMode: Top;
          Visible: false;

          Label #PlayersHint {
            Anchor: (Bottom: 8);
            Style: (...$C.@DefaultLabelStyle, Wrap: true);
            Text: "";
          }

          Group #MemberRows {
            LayoutMode: Top;
          }

          Label #InviteLabel {
            Text: "";
            Anchor: (Top: 12, Bottom: 6);
            Style: (...$C.@DefaultLabelStyle, RenderBold: true);
          }

          $C.@TextField #InvitePlayerInput {
            Anchor: (Top: 4, Height: 44, Left: 0, Right: 0);
            PlaceholderText: "";
          }

          $C.@TextButton #InviteSendButton {
            Text: "";
            Anchor: (Top: 14);
          }
        }
      }
    }
    }

    Group #MoveBuildingModal {
    LayoutMode: Middle;
    Visible: false;
    Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
    Background: #000000(0.55);

    $C.@DecoratedContainer {
      Anchor: (Width: 420);

      #Title {
        Label #MoveBuildingModalTitle {
          Style: (...$C.@TitleStyle, HorizontalAlignment: Center);
          Padding: (Horizontal: 12);
          Text: "";
        }
      }

      #Content {
        LayoutMode: Top;
        Padding: (Full: 18);

        Label #MoveBuildingModalText {
          Anchor: (Bottom: 16);
          Style: (...$C.@DefaultLabelStyle, Wrap: true);
          Text: "";
        }

        Group {
          LayoutMode: Left;

          $C.@TextButton #MoveBuildingConfirmButton {
            Text: "";
            FlexWeight: 1;
            Anchor: (Right: 8);
          }

          $C.@CancelTextButton #MoveBuildingCancelButton {
            Text: "";
            FlexWeight: 1;
            Anchor: (Left: 8);
          }
        }
      }
    }
  }
  }
}

$C.@BackButton {}
