$C = "../Common.ui";

Group {
  LayoutMode: Left;
  Anchor: (Bottom: 10);

  Button #OpenMemberName {
    LayoutMode: Left;
    Anchor: (Width: 200, Right: 8, Vertical: 4);
    Style: (
      Default: (Background: #000000(0.0)),
      Hovered: (Background: #ffffff(0.08)),
      Pressed: (Background: #ffffff(0.12))
    );

    Label #NameLabel {
      Style: (...$C.@DefaultLabelStyle, TextColor: #c9b8a3, Wrap: true);
      FlexWeight: 1;
    }
  }

  Label #RoleReadOnly {
    Anchor: (Width: 110, Right: 8, Vertical: 4);
    Visible: false;
    Style: $C.@DefaultLabelStyle;
  }

  $C.@TextButton #KickButton {
    Text: %server.aetherhaven.ui.plotmanagement.kick;
    Visible: false;
  }
}
