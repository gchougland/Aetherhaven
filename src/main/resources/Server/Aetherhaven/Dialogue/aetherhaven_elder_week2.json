{
  "id": "aetherhaven_elder_week2",
  "entry": "root",
  "nodes": {
    "root": {
      "speaker": "Elder Lyren",
      "text": "The charter still warms the stone. There is no other town left to take us in, so our people will need shelter and a hearth here. When you are ready, we should raise an inn for wanderers and kin.",
      "choices": [
        {
          "text": "I'll help build the inn.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "aetherhaven_has_town" },
              {
                "type": "not",
                "condition": {
                  "type": "or",
                  "conditions": [
                    { "type": "town_quest_active", "questId": "q_build_inn" },
                    { "type": "town_quest_completed", "questId": "q_build_inn" }
                  ]
                }
              }
            ]
          },
          "actions": [{ "type": "start_quest", "id": "q_build_inn" }],
          "next": "quest_accepted"
        },
        {
          "text": "I'm still working on the inn.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "aetherhaven_has_town" },
              { "type": "town_quest_active", "questId": "q_build_inn" }
            ]
          },
          "whenFalse": "hide",
          "next": "remind_inn"
        },
        {
          "text": "The inn is built.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "aetherhaven_has_town" },
              { "type": "town_quest_active", "questId": "q_build_inn" },
              { "type": "town_has_complete_plot", "constructionId": "inn_v1" }
            ]
          },
          "whenFalse": "hide",
          "actions": [
            { "type": "complete_quest", "id": "q_build_inn" },
            { "type": "give_item", "item": "Aetherhaven_Quest_Journal", "count": 1 }
          ],
          "next": "inn_done"
        },
        {
          "text": "About a home for you...",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "aetherhaven_has_town" },
              { "type": "town_quest_completed", "questId": "q_build_inn" },
              {
                "type": "not",
                "condition": {
                  "type": "or",
                  "conditions": [
                    { "type": "town_quest_active", "questId": "q_house_elder" },
                    { "type": "town_quest_completed", "questId": "q_house_elder" }
                  ]
                }
              },
              { "type": "not", "condition": { "type": "npc_binding_is_visitor" } }
            ]
          },
          "whenFalse": "hide",
          "next": "lyren_house_offer"
        },
        {
          "text": "You're registered at the house—I wanted you to hear it from me.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_active", "questId": "q_house_elder" },
              { "type": "town_npc_home_resident_house" }
            ]
          },
          "whenFalse": "hide",
          "actions": [{ "type": "complete_quest", "id": "q_house_elder" }],
          "next": "lyren_house_finish"
        },
        {
          "text": "I'm still building your house.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_active", "questId": "q_house_elder" },
              {
                "type": "not",
                "condition": { "type": "town_npc_home_resident_house" }
              }
            ]
          },
          "whenFalse": "hide",
          "next": "lyren_house_remind"
        },
        {
          "text": "About a town hall for the village...",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "aetherhaven_has_town" },
              { "type": "town_quest_completed", "questId": "q_house_elder" },
              {
                "type": "not",
                "condition": {
                  "type": "or",
                  "conditions": [
                    { "type": "town_quest_active", "questId": "q_build_town_hall" },
                    { "type": "town_quest_completed", "questId": "q_build_town_hall" }
                  ]
                }
              },
              { "type": "not", "condition": { "type": "npc_binding_is_visitor" } }
            ]
          },
          "whenFalse": "hide",
          "next": "town_hall_offer"
        },
        {
          "text": "I'm still building the town hall.",
          "condition": {
            "type": "and",
            "conditions": [{ "type": "town_quest_active", "questId": "q_build_town_hall" }]
          },
          "whenFalse": "hide",
          "next": "town_hall_remind"
        },
        {
          "text": "The town hall is built.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "aetherhaven_has_town" },
              { "type": "town_quest_active", "questId": "q_build_town_hall" },
              { "type": "town_has_complete_plot", "constructionId": "town_hall_v1" }
            ]
          },
          "whenFalse": "hide",
          "actions": [{ "type": "complete_quest", "id": "q_build_town_hall" }],
          "next": "town_hall_done"
        },
        {
          "text": "I'll vouch for Garren to stay as a resident.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_completed", "questId": "q_build_inn" },
              { "type": "npc_inn_pool_role", "roleId": "Aetherhaven_Blacksmith" }
            ]
          },
          "whenFalse": "hide",
          "actions": [{ "type": "promote_blacksmith" }],
          "next": "garren_promoted"
        },
        { "text": "Farewell.", "next": null }
      ]
    },
    "quest_accepted": {
      "speaker": "Elder Lyren",
      "text": "Good. Mark the ground with the plot sign and gather what the builders ask. Let it be witnessed: the timbers will follow your care.",
      "choices": [{ "text": "I'll begin.", "next": null }]
    },
    "remind_inn": {
      "speaker": "Elder Lyren",
      "text": "Take your time. When the roof is sound and the hearth laid, come tell me.",
      "choices": [{ "text": "Understood.", "next": null }]
    },
    "inn_done": {
      "speaker": "Elder Lyren",
      "text": "Word spreads already: a roof over wanderers' heads. Corin Mosscup has taken the key. Go greet him by the hearth. You've done well by Aetherhaven.",
      "choices": [{ "text": "Glad to help.", "next": null }]
    },
    "lyren_house_offer": {
      "speaker": "Elder Lyren",
      "text": "A charter is not a bed. If you can stake a small house, the same plan as any other roof in town, I'll owe you more than speeches. Craft the house token at your planning desk, place it with your staff, pay the sign, then put my name on the shelf inside.",
      "choices": [
        {
          "text": "I'll see it done.",
          "actions": [
            { "type": "start_quest", "id": "q_house_elder" },
            { "type": "give_item", "item": "Aetherhaven_Plot_Token_House", "count": 1 }
          ],
          "next": "lyren_house_accepted"
        },
        { "text": "Not yet.", "next": null }
      ]
    },
    "lyren_house_accepted": {
      "speaker": "Elder Lyren",
      "text": "Good. When the walls are up, use the management block and assign me as resident. After that, come find me—I'll want to hear it in person before we close the matter.",
      "choices": [{ "text": "Understood.", "next": null }]
    },
    "lyren_house_remind": {
      "speaker": "Elder Lyren",
      "text": "Timber and patience in equal measure. When the house stands, register me on its management block, then come speak with me so we can finish this properly.",
      "choices": [{ "text": "Right.", "next": null }]
    },
    "lyren_house_finish": {
      "speaker": "Elder Lyren",
      "text": "Then it is settled. A roof under the charter, and a bed that doesn't ask permission. Thank you for seeing it through.",
      "choices": [{ "text": "Welcome home.", "next": null }]
    },
    "garren_promoted": {
      "speaker": "Elder Lyren",
      "text": "Then Garren is one of us, not a rumor passing through. He can ask for a roof like anyone else who stays.",
      "choices": [{ "text": "Good.", "next": null }]
    },
    "town_hall_offer": {
      "speaker": "Elder Lyren",
      "text": "A home was the first roof. Next we need a hall: a shelf for the charter, a desk for plans, and a chest for what the town holds in common. Stake the plot, pay the builders, and we'll have a place that belongs to everyone.",
      "choices": [
        {
          "text": "I'll raise the town hall.",
          "actions": [
            { "type": "start_quest", "id": "q_build_town_hall" },
            { "type": "give_item", "item": "Aetherhaven_Plot_Token_Town_Hall", "count": 1 }
          ],
          "next": "town_hall_accepted"
        },
        { "text": "Not yet.", "next": null }
      ]
    },
    "town_hall_accepted": {
      "speaker": "Elder Lyren",
      "text": "Good. Use your staff with the town hall token, pay the sign, and when the timbers stand, come tell me.",
      "choices": [{ "text": "Understood.", "next": null }]
    },
    "town_hall_remind": {
      "speaker": "Elder Lyren",
      "text": "Stone and ledger in good time. When the hall is complete, say the word.",
      "choices": [{ "text": "Right.", "next": null }]
    },
    "town_hall_done": {
      "speaker": "Elder Lyren",
      "text": "Then Aetherhaven has a proper heart. Records, plans, and the treasury under one roof, with a desk where I can work for us all.",
      "choices": [{ "text": "Glad to help.", "next": null }]
    },
    "rep_reward_25": {
      "speaker": "Elder Lyren",
      "text": "server.aetherhaven.reputation.reward.elder.25",
      "actions": [{ "type": "reputation_reward_grant", "rewardId": "rep_elder_25" }],
      "choices": [{ "text": "server.aetherhaven.reputation.reward.continue", "next": "root" }]
    },
    "rep_reward_50": {
      "speaker": "Elder Lyren",
      "text": "server.aetherhaven.reputation.reward.elder.50",
      "actions": [{ "type": "reputation_reward_grant", "rewardId": "rep_elder_50" }],
      "choices": [{ "text": "server.aetherhaven.reputation.reward.continue", "next": "root" }]
    },
    "rep_reward_75": {
      "speaker": "Elder Lyren",
      "text": "server.aetherhaven.reputation.reward.elder.75",
      "actions": [{ "type": "reputation_reward_grant", "rewardId": "rep_elder_75" }],
      "choices": [{ "text": "server.aetherhaven.reputation.reward.continue", "next": "root" }]
    }
  }
}
