{
  "id": "aetherhaven_blacksmith",
  "entry": "root",
  "nodes": {
    "root": {
      "speaker": "Garren Vale",
      "text": "Garren Vale. Fine forge weather, if the wind stays out of the coals. I'm not here for sightseeing. Metal out here misbehaves, and someone has to teach it manners.",
      "choices": [
        {
          "text": "About a home in town...",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_completed", "questId": "q_build_inn" },
              {
                "type": "not",
                "condition": {
                  "type": "or",
                  "conditions": [
                    { "type": "town_quest_active", "questId": "q_house_blacksmith" },
                    { "type": "town_quest_completed", "questId": "q_house_blacksmith" }
                  ]
                }
              },
              { "type": "not", "condition": { "type": "npc_binding_is_visitor" } }
            ]
          },
          "whenFalse": "hide",
          "next": "garren_house_offer"
        },
        {
          "text": "You're registered at the house.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_active", "questId": "q_house_blacksmith" },
              { "type": "town_npc_home_resident_house" }
            ]
          },
          "whenFalse": "hide",
          "actions": [{ "type": "complete_quest", "id": "q_house_blacksmith" }],
          "next": "garren_house_finish"
        },
        {
          "text": "I'm still building your house.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_active", "questId": "q_house_blacksmith" },
              {
                "type": "not",
                "condition": { "type": "town_npc_home_resident_house" }
              }
            ]
          },
          "whenFalse": "hide",
          "next": "garren_house_remind"
        },
        { "text": "Farewell.", "next": null }
      ]
    },
    "garren_house_offer": {
      "speaker": "Garren Vale",
      "text": "A roof that isn't borrowed would keep the rust off my temper. Build the house footprint, same as anyone's, then put my name on the management block when it's done.",
      "choices": [
        {
          "text": "I'll stake a house.",
          "actions": [
            { "type": "start_quest", "id": "q_house_blacksmith" },
            { "type": "give_item", "item": "Aetherhaven_Plot_Token_House", "count": 1 }
          ],
          "next": "garren_house_accepted"
        },
        { "text": "Another time.", "next": null }
      ]
    },
    "garren_house_accepted": {
      "speaker": "Garren Vale",
      "text": "Good. When the walls are up, assign me inside. After that, find me and say so—I'll want to hear it before we call it done.",
      "choices": [{ "text": "Understood.", "next": null }]
    },
    "garren_house_remind": {
      "speaker": "Garren Vale",
      "text": "Take your time. When the house stands, register me on the block, then come talk. That's when we're square.",
      "choices": [{ "text": "Right.", "next": null }]
    },
    "garren_house_finish": {
      "speaker": "Garren Vale",
      "text": "Then the roof's honest. No borrowed floor, no borrowed name. Good.",
      "choices": [{ "text": "Fair enough.", "next": null }]
    },
    "rep_reward_25": {
      "speaker": "Garren Vale",
      "text": "server.aetherhaven.reputation.reward.blacksmith.25",
      "actions": [{ "type": "reputation_reward_grant", "rewardId": "rep_blacksmith_25" }],
      "choices": [{ "text": "server.aetherhaven.reputation.reward.continue", "next": "root" }]
    },
    "rep_reward_50": {
      "speaker": "Garren Vale",
      "text": "server.aetherhaven.reputation.reward.blacksmith.50",
      "actions": [{ "type": "reputation_reward_grant", "rewardId": "rep_blacksmith_50" }],
      "choices": [{ "text": "server.aetherhaven.reputation.reward.continue", "next": "root" }]
    }
  }
}
