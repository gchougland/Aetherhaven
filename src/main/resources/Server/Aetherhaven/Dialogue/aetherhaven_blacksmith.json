{
  "id": "aetherhaven_blacksmith",
  "entry": "root",
  "nodes": {
    "root": {
      "speaker": "Garren Vale",
      "text": "Garren Vale. Wind is low enough that the forge might behave. Metal this far out has opinions. I am here to argue with it.",
      "choices": [
        {
          "text": "server.aetherhaven.dialogue.blacksmith.repairGear",
          "condition": { "type": "town_quest_completed", "questId": "q_blacksmith_shop" },
          "actions": [{ "type": "open_blacksmith_repair" }],
          "next": null
        },
        {
          "text": "server.aetherhaven.dialogue.blacksmith.openGeodes",
          "condition": { "type": "town_quest_completed", "questId": "q_blacksmith_shop" },
          "actions": [{ "type": "open_geode_ui" }],
          "next": null
        },
        {
          "text": "You wanted to talk about a house.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_completed", "questId": "q_blacksmith_shop" },
              {
                "type": "not",
                "condition": {
                  "type": "or",
                  "conditions": [
                    { "type": "town_quest_active", "questId": "q_house_blacksmith" },
                    { "type": "town_quest_completed", "questId": "q_house_blacksmith" }
                  ]
                }
              },
              { "type": "not", "condition": { "type": "npc_binding_is_visitor" } }
            ]
          },
          "whenFalse": "hide",
          "next": "garren_house_offer"
        },
        {
          "text": "Your name is on the block. I figured you should hear it.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_active", "questId": "q_house_blacksmith" },
              { "type": "town_npc_home_resident_house" }
            ]
          },
          "whenFalse": "hide",
          "actions": [{ "type": "complete_quest", "id": "q_house_blacksmith" }],
          "next": "garren_house_finish"
        },
        {
          "text": "The house is still in progress.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_active", "questId": "q_house_blacksmith" },
              {
                "type": "not",
                "condition": { "type": "town_npc_home_resident_house" }
              }
            ]
          },
          "whenFalse": "hide",
          "next": "garren_house_remind"
        },
        {
          "text": "Good to see you working the steel.",
          "condition": {
            "type": "town_quest_completed",
            "questId": "q_blacksmith_shop"
          },
          "next": "garren_done"
        },
        {
          "text": "The shop is built. The bench is ready.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_active", "questId": "q_blacksmith_shop" },
              { "type": "town_has_complete_plot", "constructionId": "plot_blacksmith_shop" }
            ]
          },
          "actions": [{ "type": "complete_quest", "id": "q_blacksmith_shop" }],
          "next": "garren_done"
        },
        {
          "text": "About the forge build...",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_active", "questId": "q_blacksmith_shop" },
              {
                "type": "not",
                "condition": {
                  "type": "town_has_complete_plot",
                  "constructionId": "plot_blacksmith_shop"
                }
              }
            ]
          },
          "next": "garren_building"
        },
        {
          "text": "You said you needed a real forge here.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "not", "condition": { "type": "town_quest_completed", "questId": "q_blacksmith_shop" } },
              { "type": "not", "condition": { "type": "town_quest_active", "questId": "q_blacksmith_shop" } }
            ]
          },
          "next": "garren_quest_shop"
        },
        {
          "text": "Mind your fingers.",
          "next": null
        }
      ]
    },
    "garren_quest_shop": {
      "speaker": "Garren Vale",
      "text": "Corin's boards are fine for sleep. They are lousy for a hammer swing. Stake a blacksmith shop with walls, a counter, and a weapon bench I can own. Craft the plot token at your planning desk, place it with your staff, and pay the sign. When it stands, meet me at the bench.",
      "choices": [
        {
          "text": "We'll get it built.",
          "actions": [
            { "type": "start_quest", "id": "q_blacksmith_shop" },
            { "type": "give_item", "item": "Aetherhaven_Plot_Token_Blacksmith_Shop", "count": 1 }
          ],
          "next": "garren_shop_accepted"
        },
        {
          "text": "Not right now.",
          "next": null
        }
      ]
    },
    "garren_shop_accepted": {
      "speaker": "Garren Vale",
      "text": "Good. I will camp at the inn until the chimney tells the truth. Then find me at the bench and we will close the ledger.",
      "choices": [{ "text": "See you there.", "next": null }]
    },
    "garren_building": {
      "speaker": "Garren Vale",
      "text": "When the shop is built, I will walk to the weapon bench and set up. Come find me there and we will call it done.",
      "choices": [
        {
          "text": "I need to drop the quest.",
          "actions": [{ "type": "abandon_quest", "id": "q_blacksmith_shop" }],
          "next": "garren_abandoned"
        },
        { "text": "I will keep at it.", "next": null }
      ]
    },
    "garren_abandoned": {
      "speaker": "Garren Vale",
      "text": "No grudge. If you still want smoke in town, ask again.",
      "choices": [{ "text": "Fair enough.", "next": null }]
    },
    "garren_done": {
      "speaker": "Garren Vale",
      "text": "Solid bench. The heat will come when the work does. We are not shipping ore across the map anymore. We use what this ground still gives.",
      "choices": [{ "text": "Hammer well.", "next": null }]
    },
    "garren_house_offer": {
      "speaker": "Garren Vale",
      "text": "The shop earns me blisters. I still want a roof I do not borrow. Same house plot as anyone. Register me when the walls are real.",
      "choices": [
        {
          "text": "I'll stake a house.",
          "actions": [
            { "type": "start_quest", "id": "q_house_blacksmith" },
            { "type": "give_item", "item": "Aetherhaven_Plot_Token_House", "count": 1 }
          ],
          "next": "garren_house_accepted"
        },
        { "text": "Another time.", "next": null }
      ]
    },
    "garren_house_accepted": {
      "speaker": "Garren Vale",
      "text": "When the place is up, put my name on the block inside, then come find me. I want to hear you say it out loud.",
      "choices": [{ "text": "You'll hear it.", "next": null }]
    },
    "garren_house_remind": {
      "speaker": "Garren Vale",
      "text": "Iron does not rush. When the house is done, register me, then come talk. That is when we are even.",
      "choices": [{ "text": "Understood.", "next": null }]
    },
    "garren_house_finish": {
      "speaker": "Garren Vale",
      "text": "Good. A roof that does not smell like someone else's stew.",
      "choices": [{ "text": "Enjoy it.", "next": null }]
    },
    "rep_reward_25": {
      "speaker": "Garren Vale",
      "text": "server.aetherhaven.reputation.reward.blacksmith.25",
      "actions": [{ "type": "reputation_reward_grant", "rewardId": "rep_blacksmith_25" }],
      "choices": [{ "text": "server.aetherhaven.reputation.reward.continue", "next": "root" }]
    },
    "rep_reward_50": {
      "speaker": "Garren Vale",
      "text": "server.aetherhaven.reputation.reward.blacksmith.50",
      "actions": [{ "type": "reputation_reward_grant", "rewardId": "rep_blacksmith_50" }],
      "choices": [{ "text": "server.aetherhaven.reputation.reward.continue", "next": "root" }]
    }
  }
}
