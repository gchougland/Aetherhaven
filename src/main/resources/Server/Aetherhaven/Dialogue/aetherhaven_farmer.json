{
  "id": "aetherhaven_farmer",
  "entry": "root",
  "nodes": {
    "root": {
      "speaker": "Irienne Mossmark",
      "text": "Irienne Mossmark. Dirt does not care who owned it yesterday. It cares what you feed it tomorrow. I slept enough nights on Corin's floor to know a warm bowl beats pride.",
      "choices": [
        {
          "text": "You wanted to talk about your own place.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_completed", "questId": "q_farm_plot" },
              {
                "type": "not",
                "condition": {
                  "type": "or",
                  "conditions": [
                    { "type": "town_quest_active", "questId": "q_house_farmer" },
                    { "type": "town_quest_completed", "questId": "q_house_farmer" }
                  ]
                }
              },
              { "type": "not", "condition": { "type": "npc_binding_is_visitor" } }
            ]
          },
          "whenFalse": "hide",
          "next": "irienne_house_offer"
        },
        {
          "text": "Your name is on the shelf. Figured you'd want to hear it.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_active", "questId": "q_house_farmer" },
              { "type": "town_npc_home_resident_house" }
            ]
          },
          "whenFalse": "hide",
          "actions": [{ "type": "complete_quest", "id": "q_house_farmer" }],
          "next": "irienne_house_finish"
        },
        {
          "text": "Your house is still rising.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_active", "questId": "q_house_farmer" },
              {
                "type": "not",
                "condition": { "type": "town_npc_home_resident_house" }
              }
            ]
          },
          "whenFalse": "hide",
          "next": "irienne_house_remind"
        },
        {
          "text": "Good to see the farm feeding you.",
          "condition": {
            "type": "town_quest_completed",
            "questId": "q_farm_plot"
          },
          "next": "irienne_done"
        },
        {
          "text": "The farm is ready when you are.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_active", "questId": "q_farm_plot" },
              { "type": "town_has_complete_plot", "constructionId": "plot_farm" }
            ]
          },
          "actions": [{ "type": "complete_quest", "id": "q_farm_plot" }],
          "next": "irienne_done"
        },
        {
          "text": "About the fields...",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_active", "questId": "q_farm_plot" },
              {
                "type": "not",
                "condition": {
                  "type": "town_has_complete_plot",
                  "constructionId": "plot_farm"
                }
              }
            ]
          },
          "next": "irienne_building"
        },
        {
          "text": "You said you could use a farmer in town.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "not", "condition": { "type": "town_quest_completed", "questId": "q_farm_plot" } },
              { "type": "not", "condition": { "type": "town_quest_active", "questId": "q_farm_plot" } }
            ]
          },
          "next": "irienne_quest_farm"
        },
        {
          "text": "Get some rest.",
          "next": null
        }
      ]
    },
    "irienne_quest_farm": {
      "speaker": "Irienne Mossmark",
      "text": "I have been counting cracks in Corin's floorboards and dreaming of rows with my name on them. Stake a farm plot, fence it, set the bench. Craft the plot token at your planning desk, place it with your staff, pay the sign. I will meet you at the farming bench when the ground is ready.",
      "choices": [
        {
          "text": "We'll get it built.",
          "actions": [
            { "type": "start_quest", "id": "q_farm_plot" },
            { "type": "give_item", "item": "Aetherhaven_Plot_Token_Farm", "count": 1 }
          ],
          "next": "irienne_accepted"
        },
        {
          "text": "Not right now.",
          "next": null
        }
      ]
    },
    "irienne_accepted": {
      "speaker": "Irienne Mossmark",
      "text": "I will stay at the inn until the soil stops pretending it is floorboards. Then find me behind the bench with mud on my boots.",
      "choices": [{ "text": "See you there.", "next": null }]
    },
    "irienne_building": {
      "speaker": "Irienne Mossmark",
      "text": "When the plot is built, I will walk over to the farming bench and set up. Come find me there and we will call it done.",
      "choices": [
        {
          "text": "I need to drop the quest.",
          "actions": [{ "type": "abandon_quest", "id": "q_farm_plot" }],
          "next": "irienne_abandoned"
        },
        { "text": "I will keep going.", "next": null }
      ]
    },
    "irienne_abandoned": {
      "speaker": "Irienne Mossmark",
      "text": "All right. If you still want rows here, say so.",
      "choices": [{ "text": "Will do.", "next": null }]
    },
    "irienne_done": {
      "speaker": "Irienne Mossmark",
      "text": "That plot will feed more than complaints. I will keep the beds turning while the town grows.",
      "choices": [{ "text": "Grow well.", "next": null }]
    },
    "irienne_house_offer": {
      "speaker": "Irienne Mossmark",
      "text": "The fields are honest work. I still want a door that is not the inn's. Same token as anyone. Build it, then list me on the shelf.",
      "choices": [
        {
          "text": "I'll build it.",
          "actions": [
            { "type": "start_quest", "id": "q_house_farmer" },
            { "type": "give_item", "item": "Aetherhaven_Plot_Token_House", "count": 1 }
          ],
          "next": "irienne_house_accepted"
        },
        { "text": "Not yet.", "next": null }
      ]
    },
    "irienne_house_accepted": {
      "speaker": "Irienne Mossmark",
      "text": "When the roof holds, register me on the block, then find me. I want to end this with both feet on my own floorboards.",
      "choices": [{ "text": "Count on it.", "next": null }]
    },
    "irienne_house_remind": {
      "speaker": "Irienne Mossmark",
      "text": "Wood and weather take their time. When the house is done, assign me, then come tell me the rest.",
      "choices": [{ "text": "I'll find you.", "next": null }]
    },
    "irienne_house_finish": {
      "speaker": "Irienne Mossmark",
      "text": "Roots under my own rafters. That is the crop I wanted.",
      "choices": [{ "text": "Glad to hear it.", "next": null }]
    },
    "rep_reward_25": {
      "speaker": "Irienne Mossmark",
      "text": "server.aetherhaven.reputation.reward.farmer.25",
      "actions": [{ "type": "reputation_reward_grant", "rewardId": "rep_farmer_25" }],
      "choices": [{ "text": "server.aetherhaven.reputation.reward.continue", "next": "root" }]
    },
    "rep_reward_50": {
      "speaker": "Irienne Mossmark",
      "text": "server.aetherhaven.reputation.reward.farmer.50",
      "actions": [{ "type": "reputation_reward_grant", "rewardId": "rep_farmer_50" }],
      "choices": [{ "text": "server.aetherhaven.reputation.reward.continue", "next": "root" }]
    },
    "rep_reward_75": {
      "speaker": "Irienne Mossmark",
      "text": "server.aetherhaven.reputation.reward.farmer.75",
      "actions": [{ "type": "reputation_reward_grant", "rewardId": "rep_farmer_75" }],
      "choices": [{ "text": "server.aetherhaven.reputation.reward.continue", "next": "root" }]
    },
    "rep_reward_100": {
      "speaker": "Irienne Mossmark",
      "text": "server.aetherhaven.reputation.reward.farmer.100",
      "actions": [{ "type": "reputation_reward_grant", "rewardId": "rep_farmer_100" }],
      "choices": [{ "text": "server.aetherhaven.reputation.reward.continue", "next": "root" }]
    }
  }
}
