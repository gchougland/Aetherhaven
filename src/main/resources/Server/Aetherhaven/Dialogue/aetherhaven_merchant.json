{
  "id": "aetherhaven_merchant",
  "entry": "root",
  "nodes": {
    "root": {
      "speaker": "Vex Sunderlane",
      "text": "Vex Sunderlane. I buy salvage, sell hope, and count coins twice. Your inn with a working hearth is already the best shop front for miles. Everything else is negotiation.",
      "choices": [
        {
          "text": "Browse your wares (gold coins).",
          "condition": { "type": "town_quest_completed", "questId": "q_merchant_stall" },
          "actions": [{ "type": "open_barter_shop", "shop": "Aetherhaven_Vex_Merchant" }],
          "next": null
        },
        {
          "text": "server.aetherhaven.dialogue.merchant.appraiseJewelry",
          "condition": { "type": "town_quest_completed", "questId": "q_merchant_stall" },
          "actions": [{ "type": "open_jewelry_appraisal", "chargeGold": true }],
          "next": null
        },
        {
          "text": "You mentioned wanting a house.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_completed", "questId": "q_merchant_stall" },
              {
                "type": "not",
                "condition": {
                  "type": "or",
                  "conditions": [
                    { "type": "town_quest_active", "questId": "q_house_merchant" },
                    { "type": "town_quest_completed", "questId": "q_house_merchant" }
                  ]
                }
              },
              { "type": "not", "condition": { "type": "npc_binding_is_visitor" } }
            ]
          },
          "whenFalse": "hide",
          "next": "vex_house_offer"
        },
        {
          "text": "I put you on the ledger. Paper should match reality.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_active", "questId": "q_house_merchant" },
              { "type": "town_npc_home_resident_house" }
            ]
          },
          "whenFalse": "hide",
          "actions": [{ "type": "complete_quest", "id": "q_house_merchant" }],
          "next": "vex_house_finish"
        },
        {
          "text": "Your house is still on the pile.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_active", "questId": "q_house_merchant" },
              {
                "type": "not",
                "condition": { "type": "town_npc_home_resident_house" }
              }
            ]
          },
          "whenFalse": "hide",
          "next": "vex_house_remind"
        },
        {
          "text": "Good to see you trading here.",
          "condition": {
            "type": "town_quest_completed",
            "questId": "q_merchant_stall"
          },
          "next": "vex_done"
        },
        {
          "text": "The stall is up. Come see.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_active", "questId": "q_merchant_stall" },
              { "type": "town_has_complete_plot", "constructionId": "plot_market_stall" }
            ]
          },
          "actions": [{ "type": "complete_quest", "id": "q_merchant_stall" }],
          "next": "vex_done"
        },
        {
          "text": "About the stall build...",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_active", "questId": "q_merchant_stall" },
              {
                "type": "not",
                "condition": {
                  "type": "town_has_complete_plot",
                  "constructionId": "plot_market_stall"
                }
              }
            ]
          },
          "next": "vex_building"
        },
        {
          "text": "You asked me to find space for a stall.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "not", "condition": { "type": "town_quest_completed", "questId": "q_merchant_stall" } },
              { "type": "not", "condition": { "type": "town_quest_active", "questId": "q_merchant_stall" } }
            ]
          },
          "next": "vex_quest_stall"
        },
        {
          "text": "Keep your purse closed in the wind.",
          "next": null
        }
      ]
    },
    "vex_quest_stall": {
      "speaker": "Vex Sunderlane",
      "text": "I need a little roof and a counter I can lean on. You place it with your staff while you hold the token I hand you. Materials are your problem. I will run the counter when the nails hold.",
      "choices": [
        {
          "text": "I'll build it.",
          "actions": [{ "type": "start_quest", "id": "q_merchant_stall" }],
          "next": "vex_accepted"
        },
        {
          "text": "Not right now.",
          "next": null
        }
      ]
    },
    "vex_accepted": {
      "speaker": "Vex Sunderlane",
      "text": "I will camp at Corin's until the stall is standing. Safer than a ditch, and the soup is better.",
      "choices": [{ "text": "See you when it is up.", "next": null }]
    },
    "vex_building": {
      "speaker": "Vex Sunderlane",
      "text": "When the stall is built, I will head over and open shop. Come find me there and we will wrap this up.",
      "choices": [
        {
          "text": "I need to drop the quest.",
          "actions": [{ "type": "abandon_quest", "id": "q_merchant_stall" }],
          "next": "vex_abandoned"
        },
        { "text": "I will keep working on it.", "next": null }
      ]
    },
    "vex_abandoned": {
      "speaker": "Vex Sunderlane",
      "text": "Fair. If you change your mind, the offer stays.",
      "choices": [{ "text": "Thanks.", "next": null }]
    },
    "vex_done": {
      "speaker": "Vex Sunderlane",
      "text": "Stall looks honest. Trade will be thin at first. We grow it the slow way, same as everything worth keeping.",
      "choices": [{ "text": "Here's to that.", "next": null }]
    },
    "vex_house_offer": {
      "speaker": "Vex Sunderlane",
      "text": "Stock belongs on shelves. My boots belong somewhere dry. Same house token as the rest of town. Register me when it is built.",
      "choices": [
        {
          "text": "I'll stake a house.",
          "actions": [{ "type": "start_quest", "id": "q_house_merchant" }],
          "next": "vex_house_accepted"
        },
        { "text": "Another time.", "next": null }
      ]
    },
    "vex_house_accepted": {
      "speaker": "Vex Sunderlane",
      "text": "When the door swings, put my name on the block, then find me. I want the story, not just the ink.",
      "choices": [{ "text": "You will get both.", "next": null }]
    },
    "vex_house_remind": {
      "speaker": "Vex Sunderlane",
      "text": "Houses take seasons sometimes. Finish it, assign me, then come back and we will balance the ledger.",
      "choices": [{ "text": "I'll come back.", "next": null }]
    },
    "vex_house_finish": {
      "speaker": "Vex Sunderlane",
      "text": "There. A door that knows my knock. That beats a full strongbox.",
      "choices": [{ "text": "Enjoy it.", "next": null }]
    },
    "rep_reward_50": {
      "speaker": "Vex Sunderlane",
      "text": "server.aetherhaven.reputation.reward.merchant.50",
      "actions": [{ "type": "reputation_reward_grant", "rewardId": "rep_merchant_50" }],
      "choices": [{ "text": "server.aetherhaven.reputation.reward.continue", "next": "root" }]
    }
  }
}
