# === UI: quest journal (detailed view; keys use questjournal lowercase) ===
aetherhaven.ui.questjournal.title=Журнал заданий
aetherhaven.ui.questjournal.hint=Выберите вопрос для получения подробной информации.
aetherhaven.ui.questjournal.abandon=Покидать
aetherhaven.ui.questjournal.dismissShort=×
aetherhaven.ui.questjournal.detailPlaceholder=Подробности задания
