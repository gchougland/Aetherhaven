{
  "id": "aetherhaven_merchant",
  "entry": "root",
  "nodes": {
    "root": {
      "speaker": "Vex Sunderlane",
      "text": "Vex Sunderlane. I deal in salvage, barter, and whatever still has a price. There aren't other towns to run to, so if your inn has a hearth, you've already got the best amenity left on Orbis.",
      "choices": [
        {
          "text": "Browse your wares (gold coins).",
          "condition": { "type": "town_quest_completed", "questId": "q_merchant_stall" },
          "actions": [{ "type": "open_barter_shop", "shop": "Aetherhaven_Vex_Merchant" }],
          "next": null
        },
        {
          "text": "About a home in town...",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_completed", "questId": "q_merchant_stall" },
              {
                "type": "not",
                "condition": {
                  "type": "or",
                  "conditions": [
                    { "type": "town_quest_active", "questId": "q_house_merchant" },
                    { "type": "town_quest_completed", "questId": "q_house_merchant" }
                  ]
                }
              },
              { "type": "not", "condition": { "type": "npc_binding_is_visitor" } }
            ]
          },
          "whenFalse": "hide",
          "next": "vex_house_offer"
        },
        {
          "text": "I'm still building your house.",
          "condition": {
            "type": "and",
            "conditions": [{ "type": "town_quest_active", "questId": "q_house_merchant" }]
          },
          "whenFalse": "hide",
          "next": "vex_house_remind"
        },
        {
          "text": "Glad you made it.",
          "condition": {
            "type": "town_quest_completed",
            "questId": "q_merchant_stall"
          },
          "next": "vex_done"
        },
        {
          "text": "I've finished the stall.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_active", "questId": "q_merchant_stall" },
              { "type": "town_has_complete_plot", "constructionId": "plot_market_stall" }
            ]
          },
          "actions": [{ "type": "complete_quest", "id": "q_merchant_stall" }],
          "next": "vex_done"
        },
        {
          "text": "About that stall...",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "town_quest_active", "questId": "q_merchant_stall" },
              {
                "type": "not",
                "condition": {
                  "type": "town_has_complete_plot",
                  "constructionId": "plot_market_stall"
                }
              }
            ]
          },
          "next": "vex_building"
        },
        {
          "text": "I need a place for your stall.",
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "not", "condition": { "type": "town_quest_completed", "questId": "q_merchant_stall" } },
              { "type": "not", "condition": { "type": "town_quest_active", "questId": "q_merchant_stall" } }
            ]
          },
          "next": "vex_quest_stall"
        },
        {
          "text": "Farewell.",
          "next": null
        }
      ]
    },
    "vex_quest_stall": {
      "speaker": "Vex Sunderlane",
      "text": "A small market stall is all I need, somewhere honest to stack what the ruins still give up. Place it from your plot staff while you carry the token I give you. Costs are on you, but I'll work the counter when it stands.",
      "choices": [
        {
          "text": "I'll build it.",
          "actions": [
            { "type": "start_quest", "id": "q_merchant_stall" },
            { "type": "give_item", "item": "Aetherhaven_Plot_Token_Market_Stall", "count": 1 }
          ],
          "next": "vex_accepted"
        },
        {
          "text": "Not right now.",
          "next": null
        }
      ]
    },
    "vex_accepted": {
      "speaker": "Vex Sunderlane",
      "text": "Good. I'll camp at Corin's inn until the stall is ready. Fewer teeth out there than in a good soup.",
      "choices": [{ "text": "See you soon.", "next": null }]
    },
    "vex_building": {
      "speaker": "Vex Sunderlane",
      "text": "Take your time. When the stall is built, I'll head over and open shop. Come find me there and we'll wrap this up.",
      "choices": [
        {
          "text": "I need to drop the quest.",
          "actions": [{ "type": "abandon_quest", "id": "q_merchant_stall" }],
          "next": "vex_abandoned"
        },
        { "text": "Understood.", "next": null }
      ]
    },
    "vex_abandoned": {
      "speaker": "Vex Sunderlane",
      "text": "No harm done. If you change your mind, ask again about the stall.",
      "choices": [{ "text": "Farewell.", "next": null }]
    },
    "vex_done": {
      "speaker": "Vex Sunderlane",
      "text": "The stall looks solid. Trade'll be thin at first. There's no next town over to lean on, but we'll grow it. That's how rebuilding works.",
      "choices": [{ "text": "Good luck.", "next": null }]
    },
    "vex_house_offer": {
      "speaker": "Vex Sunderlane",
      "text": "The stall is honest work, but I'd like a shelf that isn't inventory. Build the house plot with the same footprint as anyone else, then register me on the management block when it's up.",
      "choices": [
        {
          "text": "I'll stake a house.",
          "actions": [
            { "type": "start_quest", "id": "q_house_merchant" },
            { "type": "give_item", "item": "Aetherhaven_Plot_Token_House", "count": 1 }
          ],
          "next": "vex_house_accepted"
        },
        { "text": "Another time.", "next": null }
      ]
    },
    "vex_house_accepted": {
      "speaker": "Vex Sunderlane",
      "text": "Good. When the walls are yours to open, put my name on the block inside. That's the proof.",
      "choices": [{ "text": "Understood.", "next": null }]
    },
    "vex_house_remind": {
      "speaker": "Vex Sunderlane",
      "text": "Take your time. When the house stands, assign me there and we'll call it settled.",
      "choices": [{ "text": "Right.", "next": null }]
    },
    "rep_reward_25": {
      "speaker": "Vex Sunderlane",
      "text": "server.aetherhaven.reputation.reward.merchant.25",
      "actions": [{ "type": "reputation_reward_grant", "rewardId": "rep_merchant_25" }],
      "choices": [{ "text": "server.aetherhaven.reputation.reward.continue", "next": "root" }]
    },
    "rep_reward_50": {
      "speaker": "Vex Sunderlane",
      "text": "server.aetherhaven.reputation.reward.merchant.50",
      "actions": [{ "type": "reputation_reward_grant", "rewardId": "rep_merchant_50" }],
      "choices": [{ "text": "server.aetherhaven.reputation.reward.continue", "next": "root" }]
    },
    "rep_reward_75": {
      "speaker": "Vex Sunderlane",
      "text": "server.aetherhaven.reputation.reward.merchant.75",
      "actions": [{ "type": "reputation_reward_grant", "rewardId": "rep_merchant_75" }],
      "choices": [{ "text": "server.aetherhaven.reputation.reward.continue", "next": "root" }]
    }
  }
}
