{
  "Type": "Component",
  "Class": "Instruction",
  "Interface": "Hytale.Instruction.Intelligent.Idle.Motion",
  "$Comment": "Looped WanderInRectGroundPreference + pause. DefaultGroundWeight applies to normal terrain; ObstacleWeight penalizes bench/seat/bed blocks. Optional GroundWeights override by BlockTypeId.",
  "Parameters": {
    "WanderRectTimer": {
      "Value": [3, 8],
      "Description": "Seconds (min,max) for each WanderInRect phase"
    },
    "PauseTimer": {
      "Value": [2, 5],
      "Description": "Seconds (min,max) for each Nothing pause between wander bursts"
    }
  },
  "Content": {
    "Sensor": { "Type": "Any" },
    "BodyMotion": {
      "Type": "Sequence",
      "Looped": true,
      "Motions": [
        {
          "Type": "Timer",
          "Time": { "Compute": "WanderRectTimer" },
          "Motion": {
            "Type": "WanderInRectGroundPreference",
            "Width": 4,
            "Depth": 4,
            "MaxHeadingChange": 90,
            "DefaultGroundWeight": 1.0,
            "ObstacleWeight": 0.12,
            "GroundWeights": []
          }
        },
        {
          "Type": "Timer",
          "Time": { "Compute": "PauseTimer" },
          "Motion": { "Type": "Nothing" }
        }
      ]
    }
  }
}
